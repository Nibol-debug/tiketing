      var vSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Vehicles');
      if (vSheet) {
        var vRaw = vSheet.getDataRange().getValues();
        var vRawMap = getColumnMap(vSheet);
        for (var vi = 1; vi < vRaw.length; vi++) {
          vehiclesData.push({ id: vRaw[vi][vRawMap['id_kendaraan']], nama: vRaw[vi][vRawMap['nama_kendaraan']] + ' (' + vRaw[vi][vRawMap['plat_nomor']] + ')' });
        }
      }
    } catch(e) {}
    
    var vehicleMapById = {};
    vehiclesData.forEach(function(v) { vehicleMapById[v.id] = v.nama; });
    
    var driversData = [];
    try {
      var dSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Drivers');
      if (dSheet) {
        var dRaw = dSheet.getDataRange().getValues();
        var dRawMap = getColumnMap(dSheet);
        for (var di = 1; di < dRaw.length; di++) {
          driversData.push({ id: dRaw[di][dRawMap['id_driver']], nama: dRaw[di][dRawMap['nama_driver']] });
        }
      }
    } catch(e) {}
    var driverMapById = {};
    driversData.forEach(function(d) { driverMapById[d.id] = d.nama; });
    
    for (var j = 1; j < vData.length; j++) {
      var vStatus = String(vData[j][vMap['status']] || '').toLowerCase();
      if (vStatus === 'reject' || vStatus === 'cancelled' || vStatus === 'batal') continue;
      
      var vtgl = vData[j][vMap['tgl_berangkat']];
      var vtglStr = '';
      if (vtgl instanceof Date) {
        vtglStr = Utilities.formatDate(vtgl, Session.getScriptTimeZone(), 'yyyy-MM-dd');
