      +     (ticketNama ? '<p style="margin:6px 0 0;font-size:13px;"><strong>Pemohon:</strong> ' + ticketNama + '</p>' : '')
      +   '</div>'
      +   '<table style="width:100%;border-collapse:collapse;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">'
      +     '<thead><tr style="background:#f1f5f9;">'
      +       '<th style="padding:8px 12px;text-align:left;font-size:12px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Nama File</th>'
      +       '<th style="padding:8px 12px;text-align:center;font-size:12px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Aksi</th>'
      +     '</tr></thead>'
      +     '<tbody>' + lampiranRows + '</tbody>'
      +   '</table>'
      +   '<p style="font-size:12px;color:#94a3b8;text-align:center;margin-top:20px;padding-top:12px;border-top:1px solid #f1f5f9;">Email otomatis dari Sistem Ticketing.</p>'
      + '</div></div>';

    MailApp.sendEmail({ to: adminEmail, subject: subjek, htmlBody: htmlBody });

    // Also send to finance admin if configured
    if (conf.finance_admin_email) {
      MailApp.sendEmail({ to: conf.finance_admin_email, subject: subjek, htmlBody: htmlBody });
    }

    return { success: true };
  } catch(e) {
    Logger.log('Gagal kirim email lampiran admin: ' + e.toString());
    return { success: false, message: e.toString() };
  }
}

