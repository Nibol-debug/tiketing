// --- NOTIFIKASI LAMPIRAN KE ADMIN ---
function notifyAdminAttachments(ticketId, attachmentsParam) {
  try {
    const conf = getNotifConfig();
    if (conf.enable_email !== 'true') return { success: true, skipped: true };
    const adminEmail = conf.admin_email;
    if (!adminEmail) return { success: true, skipped: true };

    const ss = SpreadsheetApp.getActiveSpreadsheet();

    var attachments = [];
    if (attachmentsParam && Array.isArray(attachmentsParam)) {
      attachments = attachmentsParam;
    } else {
      const tdSheet = ss.getSheetByName('Ticket_Details');
      if (tdSheet && tdSheet.getLastRow() > 1) {
        SpreadsheetApp.flush();
        const tdData = tdSheet.getDataRange().getValues();
        const tdMap = getColumnMap(tdSheet);

        var ticketIdCol = tdMap['ticket_id'] !== undefined ? tdMap['ticket_id'] : tdMap['id_tiket'];
        if (ticketIdCol === undefined) {
          var headers = tdData[0];
          for (var col = 0; col < headers.length; col++) {
            var h = String(headers[col]).toLowerCase();
            if ((h.indexOf('ticket') > -1 || h.indexOf('tiket') > -1) && h.indexOf('id') > -1) {
              ticketIdCol = col;
              break;
            }
          }
        }
        if (ticketIdCol === undefined) ticketIdCol = 1;

        var fieldNameCol = tdMap['field_name'] !== undefined ? tdMap['field_name'] : (tdMap['type'] !== undefined ? tdMap['type'] : 2);
        var fieldLabelCol = tdMap['field_label'] !== undefined ? tdMap['field_label'] : (tdMap['content'] !== undefined ? tdMap['content'] : 3);
        var fieldValueCol = tdMap['field_value'] !== undefined ? tdMap['field_value'] : (tdMap['file_url'] !== undefined ? tdMap['file_url'] : 4);

        for (var i = 1; i < tdData.length; i++) {
          var row = tdData[i];
          var tId = String(row[ticketIdCol] || '').trim();
          var typeVal = String(row[fieldNameCol] || '').trim();
          if (tId === String(ticketId).trim() && (typeVal === 'attachment' || typeVal === 'lampiran')) {
            var labelVal = String(row[fieldLabelCol] || '');
            var valueVal = String(row[fieldValueCol] || '');
            var fileName = labelVal.replace(/^(Lampiran|Attachment):\s*/i, '');
            attachments.push({ name: fileName, url: valueVal });
          }
        }
      }
    }

    if (attachments.length === 0) return { success: true, skipped: true };

    // Get ticket info for subject
    var masterSheet = ss.getSheetByName('Master_Tickets');
    var ticketNama = '';
    var ticketKategori = '';
    if (masterSheet && masterSheet.getLastRow() > 1) {
      var mData = masterSheet.getDataRange().getValues();
      var mMap = getColumnMap(masterSheet);
      for (var j = 1; j < mData.length; j++) {
        if (String(mData[j][mMap['ticket_id']] || '').trim() === ticketId) {
          ticketNama = String(mData[j][mMap['nama']] || '');
          ticketKategori = String(mData[j][mMap['kategori']] || '');
          break;
        }
      }
    }

    var subjek = '📎 Lampiran Tiket ' + ticketId + (ticketKategori ? ' [' + ticketKategori + ']' : '') + ' - ' + (ticketNama || 'Pemohon');

    var lampiranRows = '';
    for (var k = 0; k < attachments.length; k++) {
      var att = attachments[k];
      lampiranRows += '<tr>'
        + '<td style="padding:8px 12px;border-bottom:1px solid #e5e7eb;font-size:13px;">'
        + '<i style="color:#3b82f6;">📄</i> ' + att.name
        + '</td>'
        + '<td style="padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:center;">'
        + '<a href="' + att.url + '" style="background:#3b82f6;color:#fff;padding:5px 14px;border-radius:6px;text-decoration:none;font-size:12px;font-weight:bold;" target="_blank">Lihat File</a>'
        + '</td>'
        + '</tr>';
    }

    var htmlBody = '<div style="font-family:Arial,sans-serif;max-width:620px;margin:auto;border:1px solid #e0e0e0;border-radius:12px;background:#fff;overflow:hidden;">'
      + '<div style="background:linear-gradient(135deg,#3b82f6,#1d4ed8);padding:18px 25px;text-align:center;">'
      +   '<h2 style="color:#fff;margin:0;font-size:18px;">📎 Lampiran Tiket Baru</h2>'
      + '</div>'
      + '<div style="padding:25px;">'
