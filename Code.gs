// --- BE-3. DATA SERIALIZATION ---
function safeDateFormat(value) {
  if (!value) return '';
  if (value instanceof Date) {
    // Abaikan tanggal epoch tidak valid (sebelum tahun 2000)
    if (value.getFullYear() < 2000) return '';
    return Utilities.formatDate(value, Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm');
  }
  var s = String(value);
  // Abaikan nilai epoch tidak valid
  if (s.startsWith('1899') || s.startsWith('1900-01-01') || s === '0') return '';
  return s;
}

function getColumnMap(sheet) {
  const headers = sheet.getRange(1, 1, 1, Math.max(1, sheet.getLastColumn())).getValues()[0];
  return headers.reduce((acc, h, i) => {
    if (h) {
      var key = String(h).toLowerCase().trim().replace(/[\s-]/g, '_');
      acc[key] = i;
    }
    return acc;
  }, {});
}

// --- BE-4. AUTHENTICATION ---
function hashPassword(plainText) {
  if (!plainText) return '';
  const rawHash = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, plainText, Utilities.Charset.UTF_8);
  let txtHash = '';
  for (let i = 0; i < rawHash.length; i++) {
    let hashVal = rawHash[i];
    if (hashVal < 0) {
      hashVal += 256;
    }
    if (hashVal.toString(16).length == 1) {
      txtHash += '0';
    }
    txtHash += hashVal.toString(16);
  }
  return txtHash;
}

function migrasiHashPassword() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
  if (!sheet) return;
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  
  for (let i = 1; i < data.length; i++) {
    const currentPass = String(data[i][map['password']]);
    // Asumsi password lama belum di-hash (panjang SHA-256 adalah 64 karakter)
    if (currentPass && currentPass.length !== 64) {
      const newHash = hashPassword(currentPass);
      sheet.getRange(i + 1, map['password'] + 1).setValue(newHash);
    }
  }
}

function checkPermission(role, action) {
  if (role === 'Admin') return true;
  if (role === 'Operator') {
    const allowed = ['update_ticket', 'view_all'];
    return allowed.includes(action);
  }
  if (role === 'Viewer') {
    const allowed = ['view_all'];
    return allowed.includes(action);
  }
  return false;
}

function loginUser(username, password) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
  if (!sheet) return { success: false, message: 'Database User tidak ditemukan. Jalankan setupDatabase().' };
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][map['username']]) === String(username) &&
        String(data[i][map['password']]) === hashPassword(password)) {
      return {
        success: true,
        user: {
          username: data[i][map['username']],
          fullname: data[i][map['fullname']],
          role:     data[i][map['role']]
        }
      };
    }
  }
  return { success: false, message: 'Username atau Password salah!' };
}

