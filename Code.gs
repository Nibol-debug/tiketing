function formatNoWhatsApp(no) {
  let bersih = no.toString().replace(/[^0-9]/g, '');
  if (bersih.startsWith('0')) {
    bersih = '62' + bersih.slice(1);
  }
  return bersih;
}

function panggilApiWhatsApp(noTujuan, pesan) {
  const conf = getNotifConfig();
  const apiKey = conf.wa_api_key;
  // Gunakan wa_number_key jika ada, jika tidak fallback ke wa_api_key
  const numberKey = conf.wa_number_key || apiKey; 
  if (!apiKey) return;

  // Format khusus Watzap (api.watzap.id)
  const url = 'https://api.watzap.id/v1/send_message';
  
  const payload = {
    'api_key': apiKey,
    'number_key': numberKey,
    'phone_no': noTujuan,   // bukan 'receiver'
    'message': pesan        // langsung, bukan nested di 'data'
  };

  const options = {
    'method': 'post',
    'contentType': 'application/json',
    'payload': JSON.stringify(payload),
    'muteHttpExceptions': true
  };

  try {
    const respon = UrlFetchApp.fetch(url, options);
    Logger.log('Respon WA: ' + respon.getContentText());
  } catch(e) {
    Logger.log('Gagal WA: ' + e.toString());
  }
}

