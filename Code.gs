function getLobbyBookingsData() {
  var todayStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd');
  
  var roomBookings = [];
  var roomSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Room_Bookings');
  if (roomSheet && roomSheet.getLastRow() > 1) {
    var rData = roomSheet.getDataRange().getValues();
    var rMap = getColumnMap(roomSheet);
    var roomsData = getRoomsData();
    var roomMapById = {};
    roomsData.forEach(function(r) { roomMapById[r.id_ruangan] = r.nama_ruangan + ' (' + r.lokasi + ')'; });
    
    for (var i = 1; i < rData.length; i++) {
      var status = String(rData[i][rMap['status']] || '').toLowerCase();
      if (status === 'reject' || status === 'cancelled' || status === 'batal') continue;
      
      var tgl = rData[i][rMap['tgl_pakai']];
      var tglStr = '';
      if (tgl instanceof Date) {
        tglStr = Utilities.formatDate(tgl, Session.getScriptTimeZone(), 'yyyy-MM-dd');
      } else {
        tglStr = String(tgl);
      }
      
      if (tglStr === todayStr) {
        var roomId = rData[i][rMap['id_ruangan']];
        roomBookings.push({
          id: rData[i][rMap['id']],
          ruangan: roomMapById[roomId] || roomId,
          nama_pemesan: rData[i][rMap['nama_pemesan']],
          jam: rData[i][rMap['jam_mulai']] + ' - ' + rData[i][rMap['jam_selesai']],
          keperluan: rData[i][rMap['keperluan']],
          status: rData[i][rMap['status']]
        });
      }
    }
  }
  
  var vehicleBookings = [];
  var vehicleSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Vehicle_Bookings');
  if (vehicleSheet && vehicleSheet.getLastRow() > 1) {
    var vData = vehicleSheet.getDataRange().getValues();
    var vMap = getColumnMap(vehicleSheet);
