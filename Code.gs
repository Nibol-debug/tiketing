function checkOverdueBorrowings() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Master_Tickets');
  if (!sheet || sheet.getLastRow() <= 1) return;
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const today = new Date();
  today.setHours(0,0,0,0);
  
  const overdueTickets = [];
  const notifConf = getNotifConfig();
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const status = String(row[map['status']] || '').toLowerCase();
    const idAlat = String(row[map['id_alat']] || '').trim();
    
    // Only check overdue warnings if the status is exactly 'On Proses' (currently borrowed)
    const isOnProses = (status === 'on proses');
    if (isOnProses && idAlat) {
      const tglSelesaiVal = row[map['tgl_selesai_pinjam']];
      if (tglSelesaiVal) {
        let selesaiDate = null;
        if (tglSelesaiVal instanceof Date) {
          selesaiDate = new Date(tglSelesaiVal);
        } else {
          selesaiDate = new Date(tglSelesaiVal);
        }
        
        if (!isNaN(selesaiDate.getTime())) {
          selesaiDate.setHours(0,0,0,0);
          const diffTime = today.getTime() - selesaiDate.getTime();
          const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
          
          // Send notification if overdue (1 to 7 days inclusive)
          if (diffDays >= 1 && diffDays <= 7) {
            const ticketId = row[map['ticket_id']];
            const nama = row[map['nama']];
            const kontak = row[map['email']] || row[map['whatsapp']] || '';
            const namaAlat = row[map['nama_alat']];
            const jumlahPinjam = row[map['jumlah_pinjam']];
            const tglSelesaiStr = Utilities.formatDate(selesaiDate, Session.getScriptTimeZone(), 'yyyy-MM-dd');
            
            overdueTickets.push({
              ticket_id: ticketId,
              nama: nama,
              kontak: kontak,
              nama_alat: namaAlat,
              jumlah_pinjam: jumlahPinjam,
              tgl_selesai: tglSelesaiStr,
              overdue_days: diffDays
            });
            
            sendOverdueReminderToBorrower(ticketId, nama, kontak, namaAlat, jumlahPinjam, tglSelesaiStr, diffDays, notifConf);
          }
        }
      }
    }
  }
  
  if (overdueTickets.length > 0 && notifConf.enable_email === 'true' && notifConf.admin_email) {
    sendOverdueSummaryToAdmin(overdueTickets, notifConf.admin_email);
  }
}

function sendOverdueReminderToBorrower(ticketId, nama, kontak, namaAlat, jumlah, tglSelesai, diffDays, notifConf) {
  if (isEmail(kontak)) {
    if (notifConf.enable_email === 'true') {
