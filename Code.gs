    namaPemesan,
    tgl,
    jamMulai,
    jamSelesai,
    keperluan || '',
    'Open',
    '',
    new Date()
  ]);
}

function saveTicketDetails(ticketId, customFields) {
  if (!customFields || typeof customFields !== 'object') return;
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName('Ticket_Details');
  if (!sheet) {
    sheet = ss.insertSheet('Ticket_Details');
    sheet.appendRow(['id', 'ticket_id', 'field_name', 'field_label', 'field_value', 'created_at']);
    sheet.setFrozenRows(1);
  }
  var keys = Object.keys(customFields);
  for (var k = 0; k < keys.length; k++) {
    var fieldName = keys[k];
    var fieldValue = customFields[fieldName];
    if (fieldValue === undefined || fieldValue === null) fieldValue = '';

    // Resolve key if it matches specific IDs to friendly name
    var resolvedValue = String(fieldValue);
    if (fieldName === 'id_ruangan' && resolvedValue) {
      try {
        var roomSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Rooms');
        if (roomSheet) {
          var roomData = roomSheet.getDataRange().getValues();
          var roomMap = getColumnMap(roomSheet);
          for (var ri = 1; ri < roomData.length; ri++) {
            if (String(roomData[ri][roomMap['id_ruangan']]) === resolvedValue) {
              resolvedValue = String(roomData[ri][roomMap['nama_ruangan']]) + ' (' + String(roomData[ri][roomMap['lokasi']]) + ')';
              break;
            }
          }
        }
      } catch(e) {}
    } else if (fieldName === 'id_alat' && resolvedValue) {
      try {
        var invSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Inventory_Alat');
        if (invSheet) {
          var invData = invSheet.getDataRange().getValues();
          var invMap = getColumnMap(invSheet);
          for (var ii = 1; ii < invData.length; ii++) {
            if (String(invData[ii][invMap['id_alat']]) === resolvedValue) {
              resolvedValue = String(invData[ii][invMap['nama_alat']]);
              break;
            }
          }
        }
      } catch(e) {}
    } else if (fieldName === 'id_kendaraan' && resolvedValue) {
      try {
        var vhSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Vehicles');
        if (vhSheet) {
          var vhData = vhSheet.getDataRange().getValues();
          var vhMap = getColumnMap(vhSheet);
          for (var vi = 1; vi < vhData.length; vi++) {
            if (String(vhData[vi][vhMap['id_kendaraan']]) === resolvedValue) {
              resolvedValue = String(vhData[vi][vhMap['nama_kendaraan']]) + ' (' + String(vhData[vi][vhMap['plat_nomor']]) + ')';
              break;
            }
          }
        }
      } catch(e) {}
    }

    // Try to find the label from Ticket_Fields
    var label = fieldName;
    try {
      var tfSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
      if (tfSheet && tfSheet.getLastRow() > 1) {
        var tfData = tfSheet.getDataRange().getValues();
        var tfMap = getColumnMap(tfSheet);
        for (var ti = 1; ti < tfData.length; ti++) {
          if (String(tfData[ti][tfMap['field_name']]) === fieldName) {
            label = String(tfData[ti][tfMap['field_label']]);
            break;
          }
        }
      }
    } catch(e) {}
    sheet.appendRow([Date.now() + k, ticketId, fieldName, label, resolvedValue, new Date()]);
  }
}

function buildCustomFieldsHtml(customFields) {
  if (!customFields || typeof customFields !== 'object') return '';
  var html = '<table style="width:100%;border-collapse:collapse;font-size:13px;color:#374151;border-radius:6px;overflow:hidden;">';
  var keys = Object.keys(customFields);
  var tfSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
  var tfData = tfSheet ? tfSheet.getDataRange().getValues() : [];
  var tfMap = tfSheet ? getColumnMap(tfSheet) : {};
  
  var hasData = false;
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    var val = customFields[key];
    if (val === undefined || val === null || val === '') continue;
    
    var label = key;
    if (tfSheet && tfData.length > 1) {
      for (var ti = 1; ti < tfData.length; ti++) {
        if (String(tfData[ti][tfMap['field_name']]) === key) {
          label = String(tfData[ti][tfMap['field_label']]);
          break;
        }
      }
    }
    if (label === key) {
      label = key.split('_').map(function(w) { return w.charAt(0).toUpperCase() + w.slice(1); }).join(' ');
    }
    
    // Resolve IDs to names
    if (key === 'id_ruangan') {
      try {
        var roomSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Rooms');
        if (roomSheet) {
          var roomData = roomSheet.getDataRange().getValues();
          var roomMap = getColumnMap(roomSheet);
          for (var ri = 1; ri < roomData.length; ri++) {
            if (String(roomData[ri][roomMap['id_ruangan']]) === val) {
              val = String(roomData[ri][roomMap['nama_ruangan']]) + ' (' + String(roomData[ri][roomMap['lokasi']]) + ')';
              break;
            }
          }
        }
      } catch(e) {}
    }
    if (key === 'id_alat') {
      try {
        var invSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Inventory_Alat');
        if (invSheet) {
          var invData = invSheet.getDataRange().getValues();
          var invMap = getColumnMap(invSheet);
          for (var ii = 1; ii < invData.length; ii++) {
            if (String(invData[ii][invMap['id_alat']]) === val) {
              val = String(invData[ii][invMap['nama_alat']]);
              break;
            }
          }
        }
      } catch(e) {}
    }
    if (key === 'id_kendaraan') {
      try {
        var vhSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Vehicles');
        if (vhSheet) {
          var vhData = vhSheet.getDataRange().getValues();
          var vhMap = getColumnMap(vhSheet);
          for (var vi = 1; vi < vhData.length; vi++) {
            if (String(vhData[vi][vhMap['id_kendaraan']]) === val) {
              val = String(vhData[vi][vhMap['nama_kendaraan']]) + ' (' + String(vhData[vi][vhMap['plat_nomor']]) + ')';
              break;
            }
          }
        }
      } catch(e) {}
    }

    // Skip internal/system fields that don't perlu ditampilkan
    if (key === 'info_aturan') continue;

    html += '<tr><td style="padding:5px 8px;font-weight:bold;width:38%;background:#f9fafb;border-bottom:1px solid #f0f4f8;">' + label + ':</td>'
          + '<td style="padding:5px 8px;border-bottom:1px solid #f0f4f8;">' + val + '</td></tr>';
    hasData = true;
  }
  html += '</table>';
  return hasData ? html : '';
}

function buildCustomFieldsText(customFields) {
  if (!customFields || typeof customFields !== 'object') return '';
  var text = '';
  var keys = Object.keys(customFields);
  var tfSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
  var tfData = tfSheet ? tfSheet.getDataRange().getValues() : [];
  var tfMap = tfSheet ? getColumnMap(tfSheet) : {};
  
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    var val = customFields[key];
    if (val === undefined || val === null || val === '') continue;
    
    var label = key;
    if (tfSheet && tfData.length > 1) {
      for (var ti = 1; ti < tfData.length; ti++) {
        if (String(tfData[ti][tfMap['field_name']]) === key) {
          label = String(tfData[ti][tfMap['field_label']]);
          break;
        }
      }
    }
    if (label === key) {
      label = key.split('_').map(function(w) { return w.charAt(0).toUpperCase() + w.slice(1); }).join(' ');
    }
    
    // Resolve IDs to names
    if (key === 'id_ruangan') {
      try {
        var roomSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Rooms');
        if (roomSheet) {
          var roomData = roomSheet.getDataRange().getValues();
          var roomMap = getColumnMap(roomSheet);
          for (var ri = 1; ri < roomData.length; ri++) {
            if (String(roomData[ri][roomMap['id_ruangan']]) === val) {
              val = String(roomData[ri][roomMap['nama_ruangan']]) + ' (' + String(roomData[ri][roomMap['lokasi']]) + ')';
              break;
            }
          }
        }
      } catch(e) {}
    }
    if (key === 'id_alat') {
      try {
        var invSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Inventory_Alat');
        if (invSheet) {
          var invData = invSheet.getDataRange().getValues();
          var invMap = getColumnMap(invSheet);
          for (var ii = 1; ii < invData.length; ii++) {
            if (String(invData[ii][invMap['id_alat']]) === val) {
              val = String(invData[ii][invMap['nama_alat']]);
              break;
            }
          }
        }
      } catch(e) {}
    }
    if (key === 'id_kendaraan') {
      try {
        var vhSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Vehicles');
        if (vhSheet) {
          var vhData = vhSheet.getDataRange().getValues();
          var vhMap = getColumnMap(vhSheet);
          for (var vi = 1; vi < vhData.length; vi++) {
            if (String(vhData[vi][vhMap['id_kendaraan']]) === val) {
              val = String(vhData[vi][vhMap['nama_kendaraan']]) + ' (' + String(vhData[vi][vhMap['plat_nomor']]) + ')';
              break;
            }
          }
        }
      } catch(e) {}
    }

    // Skip internal/system fields
    if (key === 'info_aturan') continue;

    text += '• *' + label + ':* ' + val + '\n';
  }
  return text;
}

// --- SPRINT 9: FILE UPLOAD FOR TICKETS ---

function uploadTicketAttachment(base64Data, fileName, mimeType, ticketId) {
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000);
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var configSheet = ss.getSheetByName('App_Config');
    var configData = configSheet ? configSheet.getDataRange().getValues() : [];
    var folderId = '';
    var folderRow = -1;
    
    for (var i = 1; i < configData.length; i++) {
      if (String(configData[i][0]) === 'ticket_attachments_folder_id') {
        folderId = String(configData[i][1] || '');
        folderRow = i + 1;
        break;
      }
    }
    
    var folder;
    if (!folderId) {
      folder = DriveApp.createFolder('Ticket_Attachments');
      folder.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
      if (configSheet) {
        if (folderRow > 0) {
          configSheet.getRange(folderRow, 2).setValue(folder.getId());
        } else {
          configSheet.appendRow(['ticket_attachments_folder_id', folder.getId()]);
        }
      }
    } else {
      folder = DriveApp.getFolderById(folderId);
    }
    
    // Validate size (max 4MB = 4194304 bytes)
    var decoded = Utilities.base64Decode(base64Data);
    if (decoded.length > 4194304) {
      return { success: false, message: 'Ukuran file melebihi batas 4MB' };
    }
    
    var safeFileName = ticketId + '_' + Date.now() + '_' + fileName.replace(/[^a-zA-Z0-9._-]/g, '_');
    var blob = Utilities.newBlob(decoded, mimeType, safeFileName);
    var file = folder.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    
    var fileUrl = 'https://drive.google.com/file/d/' + file.getId() + '/view';
    
    // Save attachment metadata to Ticket_Details
    var tdSheet = ss.getSheetByName('Ticket_Details');
    if (!tdSheet) {
      tdSheet = ss.insertSheet('Ticket_Details');
      tdSheet.appendRow(['id', 'ticket_id', 'field_name', 'field_label', 'field_value', 'created_at']);
      tdSheet.setFrozenRows(1);
    }
    tdSheet.appendRow([
      Date.now(),
      ticketId,
      'attachment',
      'Lampiran: ' + fileName,
      fileUrl,
      new Date()
    ]);
    
    return { success: true, fileId: file.getId(), fileUrl: fileUrl, fileName: safeFileName };
  } catch(e) {
    return { success: false, message: 'Gagal upload: ' + e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function saveTicketFieldFileDetail(ticketId, fieldName, fileUrl) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // 1. Update di Ticket_Details
  var tdSheet = ss.getSheetByName('Ticket_Details');
  if (tdSheet) {
    var tdData = tdSheet.getDataRange().getValues();
    var tdMap = getColumnMap(tdSheet);
    for (var i = 1; i < tdData.length; i++) {
      if (String(tdData[i][tdMap['ticket_id']]) === String(ticketId) && 
          String(tdData[i][tdMap['field_name']]) === String(fieldName)) {
        tdSheet.getRange(i + 1, tdMap['field_value'] + 1).setValue(fileUrl);
        break;
      }
    }
  }
  
  // 2. Update di Sheet Kategori Spesifik jika ada kolomnya
  var mtSheet = ss.getSheetByName('Master_Tickets');
  if (mtSheet) {
    var mtData = mtSheet.getDataRange().getValues();
    var mtMap = getColumnMap(mtSheet);
    var category = '';
    for (var i = 1; i < mtData.length; i++) {
      if (String(mtData[i][mtMap['ticket_id']]) === String(ticketId)) {
        category = mtData[i][mtMap['kategori']];
        break;
      }
    }
    
    if (category) {
      var cats = getCategories();
      var cat = cats.find(function(c) { return c.nama === category; });
      if (cat && cat.sheet_name) {
        var catSheet = ss.getSheetByName(cat.sheet_name);
        if (catSheet) {
          var catData = catSheet.getDataRange().getValues();
          var catMap = getColumnMap(catSheet);
          if (catMap[fieldName] !== undefined) {
            for (var j = 1; j < catData.length; j++) {
              if (String(catData[j][catMap['ticket_id']]) === String(ticketId)) {
                catSheet.getRange(j + 1, catMap[fieldName] + 1).setValue(fileUrl);
                break;
              }
            }
          }
        }
      }
    }
  }
  return { success: true };
}

