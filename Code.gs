  let stats = { total: 0, open: 0, 'on proses': 0, pending: 0, solved: 0, reject: 0 };
  let tickets = [];
  let cats = {};
  let reqs = {};
  
  const now = new Date();
  const todayYMD = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
  let newToday = 0;

  const idCol = map['id'];
  const ticketIdCol = map['ticket_id'];
  const namaCol = map['nama'];
  const waCol = map['whatsapp'] !== undefined ? map['whatsapp'] : map['kontak'];
  const emailCol = map['email'];
  const catCol = map['kategori'];
  const descCol = map['deskripsi'];
  const statusCol = map['status'];
  const createdCol = map['created_at'];

  for (let i = 1; i < data.length; i++) {
    let row = data[i];
    let status = statusCol !== undefined ? String(row[statusCol] || '').toLowerCase() : '';
    
    stats.total++;
    if (status && stats[status] !== undefined) stats[status]++;

    let cat = catCol !== undefined ? row[catCol] : '';
    if (cat) cats[cat] = (cats[cat] || 0) + 1;
    
    let nama = namaCol !== undefined ? row[namaCol] : '';
    if (nama) reqs[nama] = (reqs[nama] || 0) + 1;

    let createdDate = createdCol !== undefined ? row[createdCol] : null;
    if (createdDate instanceof Date) {
      let createdYMD = createdDate.getFullYear() + '-' + String(createdDate.getMonth() + 1).padStart(2, '0') + '-' + String(createdDate.getDate()).padStart(2, '0');
      if (createdYMD === todayYMD) newToday++;
    }

    tickets.push({
      id: idCol !== undefined ? row[idCol] : '',
      ticket_id: ticketIdCol !== undefined ? row[ticketIdCol] : '',
      nama: nama,
      whatsapp: waCol !== undefined ? row[waCol] : '',
      email: emailCol !== undefined ? row[emailCol] : '',
      divisi_pengaju: (map['divisi_pengaju'] !== undefined) ? row[map['divisi_pengaju']] : '',
      sub_divisi_pengaju: (map['sub_divisi_pengaju'] !== undefined) ? row[map['sub_divisi_pengaju']] : '',
      jabatan_pengaju: (map['jabatan_pengaju'] !== undefined) ? row[map['jabatan_pengaju']] : '',
      kategori: cat,
      sub_layanan: (map['sub_layanan'] !== undefined) ? row[map['sub_layanan']] : '',
      deskripsi: descCol !== undefined ? row[descCol] : '',
      status: statusCol !== undefined ? row[statusCol] : '',
      approval_level: (map['approval_level'] !== undefined) ? row[map['approval_level']] : '',
      catatan: (map['catatan'] !== undefined) ? row[map['catatan']] : '',
      diupdate_oleh: (map['diupdate_oleh'] !== undefined) ? row[map['diupdate_oleh']] : '',
      created_at: safeDateFormat(createdDate),
      sla_deadline: (map['sla_deadline'] !== undefined && row[map['sla_deadline']]) ? safeDateFormat(row[map['sla_deadline']]) : '',
      sla_status: (map['sla_status'] !== undefined) ? row[map['sla_status']] : '',
      id_alat: (map['id_alat'] !== undefined) ? row[map['id_alat']] : '',
      nama_alat: (map['nama_alat'] !== undefined) ? row[map['nama_alat']] : '',
      jumlah_pinjam: (map['jumlah_pinjam'] !== undefined) ? row[map['jumlah_pinjam']] : '',
      tgl_mulai_pinjam: (map['tgl_mulai_pinjam'] !== undefined && row[map['tgl_mulai_pinjam']]) ? safeDateFormat(row[map['tgl_mulai_pinjam']]) : '',
      tgl_selesai_pinjam: (map['tgl_selesai_pinjam'] !== undefined && row[map['tgl_selesai_pinjam']]) ? safeDateFormat(row[map['tgl_selesai_pinjam']]) : '',
      tgl_kembali_aktual: (map['tgl_kembali_aktual'] !== undefined && row[map['tgl_kembali_aktual']]) ? safeDateFormat(row[map['tgl_kembali_aktual']]) : '',
      kondisi_kembali: (map['kondisi_kembali'] !== undefined) ? row[map['kondisi_kembali']] : ''
    });
  }
  
  let catArray = Object.keys(cats).map(k => ({name: k, count: cats[k]})).sort((a,b) => b.count - a.count);
  let reqArray = Object.keys(reqs).map(k => ({name: k, count: reqs[k]})).sort((a,b) => b.count - a.count).slice(0, 10);

  return { 
    total: stats.total, 
    open: stats.open, 
    on_proses: stats['on proses'], 
    background_load: false, // flag indicating raw results
    pending: stats.pending, 
    solved: stats.solved, 
    reject: stats.reject, 
    tickets: tickets.reverse(),
    catCounts: catArray,
    topReqs: reqArray,
    newToday: newToday
  };
}

function getCategories() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Categories');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const result = [];
  
  for (let i = 1; i < data.length; i++) {
    result.push({
      id: data[i][map['id']],
      nama: data[i][map['nama']],
      deskripsi: (map['deskripsi'] !== undefined) ? data[i][map['deskripsi']] : '',
      sheet_name: data[i][map['sheet_name']],
      status: data[i][map['status']]
    });
  }
  return result;
}

function getSubCategories() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Sub_Categories');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const result = [];
  
  const idCol = map['id_sub'] !== undefined ? map['id_sub'] : map['id'];
  const parentCol = map['kategori'] !== undefined ? map['kategori'] : map['parent_nama'];
  const namaCol = map['nama_sub'] !== undefined ? map['nama_sub'] : map['nama'];
  const statusCol = map['status'];
  
  for (let i = 1; i < data.length; i++) {
    result.push({
      id: idCol !== undefined ? data[i][idCol] : '',
      parent_nama: parentCol !== undefined ? data[i][parentCol] : '',
      nama: namaCol !== undefined ? data[i][namaCol] : '',
      status: statusCol !== undefined ? data[i][statusCol] : ''
    });
  }
  return result;
}

function getRequesters(currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'view_all')) {
    throw new Error('Akses Ditolak: Anda tidak diizinkan melihat data pemohon.');
  }
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Requesters');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const result = [];
  
  // Support skema lama (kontak) dan baru (whatsapp + email)
  const hasWhatsapp = map['whatsapp'] !== undefined;
  const hasEmail    = map['email'] !== undefined;
  const hasKontak   = map['kontak'] !== undefined;
  const namaCol     = map['nama'];
  const totalCol    = map['total_request'];
  const lastCol     = map['last_request'];
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];

    let wa = '', email = '';
    if (hasWhatsapp) wa = String(row[map['whatsapp']] || '').trim();
    if (hasEmail)    email = String(row[map['email']] || '').trim();

    // Fallback: jika kolom kontak masih ada, distribusikan nilainya
    if (hasKontak && !wa && !email) {
      const kontak = String(row[map['kontak']] || '').trim();
      if (kontak.indexOf('@') !== -1) { email = kontak; }
      else { wa = kontak; }
    }

    // Jika whatsapp tidak ada tapi kontak ada, distribusikan juga
    if (hasWhatsapp && !wa && hasKontak) {
      const kontak = String(row[map['kontak']] || '').trim();
      if (kontak && kontak.indexOf('@') === -1) wa = kontak;
    }

    // Skip baris header atau baris kosong
    const nama = namaCol !== undefined ? String(row[namaCol] || '').trim() : '';
    if (!nama && !wa && !email) continue;

    result.push({
      whatsapp: wa,
      email: email,
      nama: nama || wa || email,
      total_request: totalCol !== undefined ? (Number(row[totalCol]) || 0) : 0,
      last_request: lastCol !== undefined ? safeDateFormat(row[lastCol]) : ''
    });
  }
  return result;
}

function getConfig() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('App_Config');
  if (!sheet || sheet.getLastRow() <= 1) return { app_name: 'Ticketing System', public_headline: 'Solusi Cepat Kendala Kamu', popup_success_message: 'Simpan ID Tiket Kamu untuk mengecek status:' };
  
  const data = sheet.getDataRange().getValues();
  let conf = {};
  for(let i=1; i<data.length; i++) {
    conf[data[i][0]] = data[i][1];
  }
  return conf;
}

