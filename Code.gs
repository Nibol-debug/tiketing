// --- MULTI-DIVISI: DYNAMIC FORM FIELDS & ROOMS ---

function getTicketFields(subKategori) {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  var data = sheet.getDataRange().getValues();
  var map = getColumnMap(sheet);
  var result = [];
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][map['nama_pengajuan']]).toLowerCase() === String(subKategori).toLowerCase()) {
      result.push({
        id_template: data[i][map['id_template']],
        nama_pengajuan: data[i][map['nama_pengajuan']],
        divisi: data[i][map['divisi']],
        field_name: data[i][map['field_name']],
        field_label: data[i][map['field_label']],
        field_type: data[i][map['field_type']],
        required: Number(data[i][map['required']]) === 1,
        options: String(data[i][map['options']] || ''),
        urutan: Number(data[i][map['urutan']]) || 0,
        field_section: String(data[i][map['field_section']] || 'detail'),
        depends_on_field: map['depends_on_field'] !== undefined ? String(data[i][map['depends_on_field']] || '') : '',
        depends_on_value: map['depends_on_value'] !== undefined ? String(data[i][map['depends_on_value']] || '') : ''
      });
    }
  }
  result.sort(function(a, b) { return a.urutan - b.urutan; });
  return result;
}

// --- ATTACHMENT HELPERS ---

/**
 * Ekstrak file ID dari URL Google Drive.
 * Format: https://drive.google.com/file/d/{ID}/view
 * Returns empty string jika bukan URL Drive yang valid.
 */
function getFileIdFromDriveUrl(url) {
  if (!url) return '';
  var m = String(url).match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
  return m ? m[1] : '';
}

/**
 * Baca semua baris attachment dari Ticket_Details untuk ticketId tertentu.
 * Returns array of { name, url, thumbUrl, isImage }
 */
function getTicketAttachments(ticketId) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName('Ticket_Details');
  if (!sheet || sheet.getLastRow() <= 1) return [];

  var data = sheet.getDataRange().getValues();
  var map = getColumnMap(sheet);
  var ticketIdCol = map['ticket_id'] !== undefined ? map['ticket_id'] : 1;
  var fieldNameCol = map['field_name'] !== undefined ? map['field_name'] : 2;
  var fieldLabelCol = map['field_label'] !== undefined ? map['field_label'] : 3;
  var fieldValueCol = map['field_value'] !== undefined ? map['field_value'] : 4;

  var attachments = [];
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][ticketIdCol]).trim() !== String(ticketId).trim()) continue;
    if (String(data[i][fieldNameCol]).trim() !== 'attachment') continue;

    var rawLabel = String(data[i][fieldLabelCol] || '');
    // Format label: "Lampiran: namafile.ext" — ambil bagian sesudah ": "
    var name = rawLabel.indexOf(': ') !== -1
      ? rawLabel.substring(rawLabel.indexOf(': ') + 2).trim()
      : rawLabel.trim();
    if (!name) name = 'Lampiran';

    var url = String(data[i][fieldValueCol] || '').trim();
    var fileId = getFileIdFromDriveUrl(url);
    var thumbUrl = fileId
      ? 'https://drive.google.com/thumbnail?id=' + fileId + '&sz=w200-h200'
      : '';

    var ext = name.toLowerCase().split('.').pop();
    var imageExts = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp'];
    var isImage = imageExts.indexOf(ext) !== -1;

    attachments.push({ name: name, url: url, thumbUrl: thumbUrl, isImage: isImage });
  }
  return attachments;
}

function getTicketDetail(ticketId) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName('Ticket_Details');
  if (!sheet) {
    sheet = ss.insertSheet('Ticket_Details');
    sheet.appendRow(['id', 'ticket_id', 'field_name', 'field_label', 'field_value', 'created_at']);
    sheet.setFrozenRows(1);
  }
  if (sheet.getLastRow() <= 1) return { details: [], attachments: [] };
  var data = sheet.getDataRange().getValues();
  var map = getColumnMap(sheet);
  
  var ticketIdCol = map['ticket_id'] !== undefined ? map['ticket_id'] : map['id_tiket'];
  if (ticketIdCol === undefined) {
    var headers = data[0];
    for (var col = 0; col < headers.length; col++) {
      var h = String(headers[col]).toLowerCase();
      if ((h.indexOf('ticket') > -1 || h.indexOf('tiket') > -1) && h.indexOf('id') > -1) {
        ticketIdCol = col;
        break;
      }
    }
  }
  if (ticketIdCol === undefined) ticketIdCol = 1;

  var fieldNameCol = map['field_name'] !== undefined ? map['field_name'] : 2;
  var fieldLabelCol = map['field_label'] !== undefined ? map['field_label'] : 3;
  var fieldValueCol = map['field_value'] !== undefined ? map['field_value'] : 4;

  var details = [];
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][ticketIdCol]).trim() !== String(ticketId).trim()) continue;
    // Pisahkan attachment — jangan masuk ke tabel detail
    if (String(data[i][fieldNameCol]).trim() === 'attachment') continue;
    details.push({
      field_name: data[i][fieldNameCol],
      field_label: data[i][fieldLabelCol],
      field_value: data[i][fieldValueCol]
    });
  }

  var attachments = getTicketAttachments(ticketId);
  return { details: details, attachments: attachments };
}

function getRoomsData() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Rooms');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  var data = sheet.getDataRange().getValues();
