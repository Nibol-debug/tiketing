function checkSlaBreaches() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Master_Tickets');
  if (!sheet) return;
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const now = new Date();
  
  const notifConf = getNotifConfig();
  const adminEmail = notifConf.admin_email;
  const isEmailActive = String(notifConf.enable_email) === 'true';
  const isWaActive = String(notifConf.enable_whatsapp) === 'true';
  
  for (let i = 1; i < data.length; i++) {
    const status = data[i][map['status']];
    if (status === 'Solved' || status === 'Reject' || status === 'Batal') continue;
    
    const deadline = data[i][map['sla_deadline']];
    if (!deadline) continue;
    
    const ticketId = data[i][map['ticket_id']];
    const nama = data[i][map['nama']];
    const subLayanan = data[i][map['sub_layanan']];
    const userWa = data[i][map['whatsapp']];
    const userEmail = data[i][map['email']];
    
    const diffWorkingDays = getWorkingDaysBetween(now, deadline);
    let threshold = '';
    let newSlaStatus = 'On Time';
    
    if (diffWorkingDays < 0) {
      threshold = 'Overdue';
      newSlaStatus = 'Overdue';
    } else if (diffWorkingDays === 1) {
      threshold = 'H-1';
      newSlaStatus = 'Warning';
    } else if (diffWorkingDays === 2) {
      threshold = 'H-2';
      newSlaStatus = 'Warning';
    }
    
    // Perbarui status SLA di sheet
    sheet.getRange(i + 1, map['sla_status'] + 1).setValue(newSlaStatus);
    
    if (threshold) {
      // Periksa apakah notifikasi untuk threshold ini sudah pernah dikirim
      if (!isSlaNotificationSent(ticketId, threshold)) {
        // Kirim Notifikasi!
        let title = '';
        let msg = '';
        
        if (threshold === 'Overdue') {
          title = `🔥 SLA OVERDUE - Tiket #${ticketId}`;
          msg = `Tiket dengan ID #${ticketId} ("${subLayanan}") atas nama ${nama} telah MELEWATI batas waktu SLA (Overdue). Harap segera diselesaikan!`;
        } else if (threshold === 'H-1') {
          title = `🚨 PERINGATAN SLA (H-1) - Tiket #${ticketId}`;
          msg = `Tiket dengan ID #${ticketId} ("${subLayanan}") atas nama ${nama} tersisa 1 HARI KERJA lagi untuk diselesaikan. Harap segera diproses!`;
        } else if (threshold === 'H-2') {
          title = `⚠️ PERINGATAN SLA (H-2) - Tiket #${ticketId}`;
          msg = `Tiket dengan ID #${ticketId} ("${subLayanan}") atas nama ${nama} tersisa 2 HARI KERJA lagi untuk diselesaikan. Harap segera ditindaklanjuti.`;
        }
        
        // 1. Notifikasi ke Admin
        if (adminEmail && isEmail(adminEmail) && isEmailActive) {
          try {
            MailApp.sendEmail({
              to: adminEmail,
              subject: title,
              htmlBody: `<div style="font-family:sans-serif;padding:20px;border:1px solid #e2e8f0;border-radius:10px;">
                <h3 style="color:#d9534f;margin-top:0;">${title}</h3>
                <p>${msg}</p>
                <hr style="border:none;border-top:1px solid #e2e8f0;margin:15px 0;">
                <small style="color:#718096;">Sistem Ticketing Internal Halo APU</small>
              </div>`
            });
          } catch(emailErr) {
            Logger.log(`Gagal kirim email SLA ke admin: ${emailErr.toString()}`);
          }
        }
        
        if (adminEmail && isWaActive) {
          try {
            const noWaAdmin = formatNoWhatsApp(adminEmail);
            if (noWaAdmin && !isNaN(noWaAdmin)) {
              panggilApiWhatsApp(noWaAdmin, `*[Halo APU]*\n\n${title}\n\n${msg}`);
            }
          } catch(waAdminErr) {
            Logger.log(`Gagal kirim WA SLA ke admin: ${waAdminErr.toString()}`);
          }
        }
        
        // 2. Notifikasi ke Pemohon/User
        if (userEmail && isEmail(userEmail) && isEmailActive) {
          try {
            MailApp.sendEmail({
              to: userEmail,
              subject: `Notifikasi SLA Tiket #${ticketId}`,
              htmlBody: `<div style="font-family:sans-serif;padding:20px;border:1px solid #e2e8f0;border-radius:10px;">
                <h3 style="color:#3182ce;margin-top:0;">Pemberitahuan Status SLA Tiket</h3>
                <p>Halo <strong>${nama}</strong>,</p>
                <p>Tiket Anda dengan ID <strong>#${ticketId}</strong> ("${subLayanan}") sedang dalam proses dengan status SLA: <strong>${threshold}</strong>.</p>
                <p>Tim kami berkomitmen untuk segera menyelesaikan kendala/permohonan Anda. Terima kasih atas kesabaran Anda.</p>
                <hr style="border:none;border-top:1px solid #e2e8f0;margin:15px 0;">
                <small style="color:#718096;">Sistem Ticketing Internal Halo APU</small>
              </div>`
            });
          } catch(emailUserErr) {
            Logger.log(`Gagal kirim email SLA ke user: ${emailUserErr.toString()}`);
          }
        }
        
        if (userWa && isWaActive) {
          try {
            const noWaUser = formatNoWhatsApp(userWa);
            if (noWaUser) {
              const userMsg = `Halo *${nama}*,\n\nNotifikasi Status SLA Tiket *#${ticketId}* ("${subLayanan}") saat ini: *${threshold}*.\n\nTim kami sedang mengupayakan penyelesaian terbaik untuk Anda. Terima kasih atas kesabarannya.`;
              panggilApiWhatsApp(noWaUser, userMsg);
            }
          } catch(waUserErr) {
            Logger.log(`Gagal kirim WA SLA ke user: ${waUserErr.toString()}`);
          }
        }
        
        // Catat ke SLA_Notif_Log agar tidak spam
        logSlaNotification(ticketId, threshold);
      }
    }
  }
}

// --- MODUL: LAPORAN BULANAN OTOMATIS ---
function generateMonthlyReport(year, month) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Master_Tickets');
  if (!sheet || sheet.getLastRow() <= 1) return null;
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  
  // Filter tiket dalam rentang bulan
  const startDate = new Date(year, month - 1, 1);
  const endDate = new Date(year, month, 0, 23, 59, 59);
  
  let totalTiket = 0;
  let solved = 0, reject = 0, open = 0, onProses = 0, pending = 0;
  let perUnit = {};
  let perPemohon = {};
  let totalSolveTime = 0;
  let solvedCount = 0;
  let perUnitSolveTime = {};
  let perUnitSolvedCount = {};
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const createdAt = row[map['created_at']];
    if (!createdAt) continue;
    
    let createdDate = createdAt instanceof Date ? createdAt : new Date(createdAt);
    if (isNaN(createdDate.getTime())) continue;
    if (createdDate < startDate || createdDate > endDate) continue;
    
    totalTiket++;
    const status = String(row[map['status']] || '').toLowerCase();
    const kategori = row[map['kategori']] || 'Lainnya';
    const nama = row[map['nama']] || 'Unknown';
    
    if (status === 'solved') solved++;
    else if (status === 'reject') reject++;
    else if (status === 'open') open++;
    else if (status === 'on proses') onProses++;
    else if (status === 'pending') pending++;
    
    perUnit[kategori] = (perUnit[kategori] || 0) + 1;
    perPemohon[nama] = (perPemohon[nama] || 0) + 1;
    
    // Hitung rata-rata waktu penyelesaian
    if (status === 'solved') {
      let solvedAtVal = (map['solved_at'] !== undefined) ? row[map['solved_at']] : null;
      if (!solvedAtVal) {
        // Fallback to createdDate so it averages as 0.0 days instead of ignoring it
        solvedAtVal = createdDate;
      }
      let solvedAt = solvedAtVal instanceof Date ? solvedAtVal : new Date(solvedAtVal);
      if (!isNaN(solvedAt.getTime())) {
        let diffDays = (solvedAt.getTime() - createdDate.getTime()) / (1000 * 60 * 60 * 24);
        // Ensure diffDays is not negative
        if (diffDays < 0) diffDays = 0;
        totalSolveTime += diffDays;
        solvedCount++;
        
        if (!perUnitSolveTime[kategori]) { perUnitSolveTime[kategori] = 0; perUnitSolvedCount[kategori] = 0; }
        perUnitSolveTime[kategori] += diffDays;
        perUnitSolvedCount[kategori]++;
      }
    }
  }
  
  // Top 5 pemohon
  let topPemohon = Object.keys(perPemohon).map(k => ({name: k, count: perPemohon[k]})).sort((a,b) => b.count - a.count).slice(0, 5);
  
  // Unit breakdown sorted
  let unitBreakdown = Object.keys(perUnit).map(k => ({name: k, count: perUnit[k]})).sort((a,b) => b.count - a.count);
  
  // Rata-rata per unit
  let avgPerUnit = {};
  Object.keys(perUnitSolveTime).forEach(k => {
    avgPerUnit[k] = perUnitSolvedCount[k] > 0 ? (perUnitSolveTime[k] / perUnitSolvedCount[k]).toFixed(1) : '-';
  });
  
  const bulanNames = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  
  return {
    bulan: bulanNames[month - 1],
    tahun: year,
    total: totalTiket,
    solved: solved,
    reject: reject,
    open: open,
    onProses: onProses,
    pending: pending,
    masihAktif: open + onProses + pending,
    pctSolved: totalTiket > 0 ? Math.round((solved / totalTiket) * 100) : 0,
    pctReject: totalTiket > 0 ? Math.round((reject / totalTiket) * 100) : 0,
    pctAktif: totalTiket > 0 ? Math.round(((open + onProses + pending) / totalTiket) * 100) : 0,
    unitBreakdown: unitBreakdown,
    topPemohon: topPemohon,
    avgSolveTime: solvedCount > 0 ? (totalSolveTime / solvedCount).toFixed(1) : '-',
    avgPerUnit: avgPerUnit
  };
}

