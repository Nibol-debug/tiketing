function checkVehicleConflict(idKendaraan, tgl, jamMulai, jamSelesai) {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Vehicle_Bookings');
  if (!sheet || sheet.getLastRow() <= 1) return { conflict: false };
  var data = sheet.getDataRange().getValues();
  var map = getColumnMap(sheet);
  for (var i = 1; i < data.length; i++) {
    var bStatus = String(data[i][map['status']] || '').toLowerCase();
    if (bStatus === 'cancelled' || bStatus === 'batal' || bStatus === 'reject' || bStatus === 'rejected') continue;
    if (String(data[i][map['id_kendaraan']]) === String(idKendaraan)) {
      var bTgl = data[i][map['tgl_berangkat']];
      var bTglStr = '';
      if (bTgl instanceof Date) {
        bTglStr = Utilities.formatDate(bTgl, Session.getScriptTimeZone(), 'yyyy-MM-dd');
      } else {
        bTglStr = String(bTgl);
      }
      if (bTglStr === String(tgl)) {
        var bStart = String(data[i][map['jam_berangkat']]);
        var bEnd = String(data[i][map['jam_kembali']]);
        if (jamMulai < bEnd && jamSelesai > bStart) {
          return {
            conflict: true,
            message: 'Kendaraan sudah dibooking pada ' + tgl + ' pukul ' + bStart + ' - ' + bEnd + ' (' + String(data[i][map['nama_pemesan']] || 'N/A') + ')'
          };
        }
      }
    }
  }
  return { conflict: false };
}

