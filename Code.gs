function sendMonthlyReport(targetYear, targetMonth) {
  try {
    let year = targetYear;
    let month = targetMonth;
    
    if (year === undefined || month === undefined) {
      const now = new Date();
      year = now.getFullYear();
      month = now.getMonth(); // 0-indexed, jadi ini = bulan sebelumnya
      if (month === 0) { month = 12; year--; }
    }
    
    const report = generateMonthlyReport(year, month);
    if (!report || report.total === 0) {
      Logger.log('Tidak ada tiket untuk laporan bulanan ' + month + '/' + year);
      
      // Fallback for testing/manual triggers:
      // If there are no tickets in the target month (e.g. May), but we are running manually (no args),
      // try sending the current month's report (e.g. June) so the admin can verify the layout works.
      if (targetYear === undefined && targetMonth === undefined) {
        const currentMonth = new Date().getMonth() + 1;
        const currentYear = new Date().getFullYear();
        Logger.log('Mencoba mengirim laporan untuk bulan berjalan: ' + currentMonth + '/' + currentYear);
        return sendMonthlyReport(currentYear, currentMonth);
      }
      return;
    }
    
    const conf = getNotifConfig();
    const adminEmail = conf.admin_email;
    if (!adminEmail) {
      Logger.log('Email admin tidak dikonfigurasi untuk laporan bulanan');
      return;
    }
    
    const htmlBody = buildMonthlyReportHtml(report);
    const subjek = '📊 Laporan Bulanan Ticketing — ' + report.bulan + ' ' + report.tahun;
    
    MailApp.sendEmail({
      to: adminEmail,
      subject: subjek,
      htmlBody: htmlBody
    });
    
    Logger.log('Laporan bulanan berhasil dikirim ke ' + adminEmail);
  } catch(e) {
    Logger.log('Gagal mengirim laporan bulanan: ' + e.toString());
  }
}

function createMonthlyReportTrigger() {
  // Hapus trigger lama kalau ada
  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(function(trigger) {
    if (trigger.getHandlerFunction() === 'sendMonthlyReport') {
      ScriptApp.deleteTrigger(trigger);
    }
  });
  
  // Buat trigger baru: setiap tanggal 1 pukul 07.00
  ScriptApp.newTrigger('sendMonthlyReport')
    .timeBased()
    .onMonthDay(1)
    .atHour(7)
    .create();
}

function dailyCheck() {
  checkOverdueBorrowings();
  checkSlaBreaches();
}

function createScheduledTriggers() {
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    const h = triggers[i].getHandlerFunction();
    if (h === 'checkOverdueBorrowings' || h === 'dailyCheck' || h === 'generateMonthlyReport') {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }
  
  // Daily check at 08:00
  ScriptApp.newTrigger('dailyCheck')
    .timeBased()
    .everyDays(1)
    .atHour(8)
    .create();
    
  // Monthly report on 1st of every month at 07:00
  ScriptApp.newTrigger('generateMonthlyReport')
    .timeBased()
    .onMonthDay(1)
    .atHour(7)
    .create();
}



// --- PENGATURAN FORM DINAMIS (FORM BUILDER) ---
function getAllTicketFields() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  var data = sheet.getDataRange().getValues();
  var map = getColumnMap(sheet);
  var result = [];
  for (var i = 1; i < data.length; i++) {
    result.push({
      row: i + 1,
      id_template: data[i][map['id_template']],
      nama_pengajuan: data[i][map['nama_pengajuan']],
      divisi: data[i][map['divisi']],
      field_name: data[i][map['field_name']],
      field_label: data[i][map['field_label']],
      field_type: data[i][map['field_type']],
      required: Number(data[i][map['required']]) === 1,
      options: String(data[i][map['options']] || ''),
      urutan: Number(data[i][map['urutan']]) || 0,
      field_section: String(data[i][map['field_section']] || 'detail'),
      depends_on_field: map['depends_on_field'] !== undefined ? String(data[i][map['depends_on_field']] || '') : '',
      depends_on_value: map['depends_on_value'] !== undefined ? String(data[i][map['depends_on_value']] || '') : ''
    });
  }
  result.sort(function(a, b) {
    if (a.nama_pengajuan === b.nama_pengajuan) return a.urutan - b.urutan;
    return a.nama_pengajuan.localeCompare(b.nama_pengajuan);
  });
  return result;
}

function saveTicketField(payload, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat mengubah field kustom.' };
  }
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
    if (!sheet) return { success: false, message: 'Sheet Ticket_Fields tidak ditemukan' };
    var map = getColumnMap(sheet);
    var newRow = [
      payload.id_template,
      payload.nama_pengajuan,
      payload.divisi || '',
      payload.field_name,
      payload.field_label,
      payload.field_type,
      payload.required ? 1 : 0,
      payload.options || '',
      payload.urutan || 1,
      payload.field_section || 'detail',
      payload.depends_on_field || '',
      payload.depends_on_value || ''
    ];
    if (payload.row && payload.row > 1) {
      sheet.getRange(payload.row, 1, 1, newRow.length).setValues([newRow]);
    } else {
      sheet.appendRow(newRow);
    }
    return { success: true };
  } catch (e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function deleteTicketField(row, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat menghapus field kustom.' };
  }
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
    if (!sheet || row <= 1) return { success: false, message: 'Data tidak valid' };
    sheet.deleteRow(row);
    return { success: true };
  } catch (e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}


// --- FORM SETTINGS (PENGATURAN FORM TERINTEGRASI) ---

function migrateTicketFieldsToFormSettings() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var tfSheet = ss.getSheetByName('Ticket_Fields');
  var fsSheet = ss.getSheetByName('Form_Settings');
  if (!tfSheet || !fsSheet || tfSheet.getLastRow() <= 1) return;

  var tfData = tfSheet.getDataRange().getValues();
  var tfMap  = getColumnMap(tfSheet);
  var fsData = fsSheet.getDataRange().getValues();
  // Collect existing field_names to avoid duplicates
  var existingFieldNames = {};
  var fsFN = getColumnMap(fsSheet);
  for (var x = 1; x < fsData.length; x++) {
    var key = String(fsData[x][fsFN['nama_pengajuan']]).toLowerCase() + '||' + String(fsData[x][fsFN['field_name']]).toLowerCase();
    existingFieldNames[key] = true;
  }

  var rowsToAdd = [];
  for (var i = 1; i < tfData.length; i++) {
    var fn     = String(tfData[i][tfMap['field_name']] || '');
    var npName = String(tfData[i][tfMap['nama_pengajuan']] || '');
    var key    = npName.toLowerCase() + '||' + fn.toLowerCase();
    if (!fn || !npName || existingFieldNames[key]) continue;
    var isInv = String(tfData[i][tfMap['field_type']]).indexOf('inventory') !== -1;
    rowsToAdd.push([
      'FS-' + (Date.now() + i) + '-' + i,
      npName,
      String(tfData[i][tfMap['divisi']] || ''),
      fn,
      String(tfData[i][tfMap['field_label']] || ''),
      String(tfData[i][tfMap['field_type']] || 'text'),
      tfData[i][tfMap['required']],
      String(tfData[i][tfMap['options']] || ''),
      Number(tfData[i][tfMap['urutan']]) || 0,
      String(tfData[i][tfMap['field_section']] || 'detail'),
      isInv ? 1 : 0,
      isInv ? fn : '',
      'System Migration',
      new Date(),
      'Active'
    ]);
  }
  if (rowsToAdd.length > 0) {
    fsSheet.getRange(fsSheet.getLastRow() + 1, 1, rowsToAdd.length, rowsToAdd[0].length).setValues(rowsToAdd);
  }
}

function getFormSettings(filterUnit, filterKategori) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var fsSheet = ss.getSheetByName('Form_Settings');
  var tfSheet = ss.getSheetByName('Ticket_Fields');

  // Jika Form_Settings belum ada atau kosong, ambil dari Ticket_Fields sebagai fallback
  var useFallback = (!fsSheet || fsSheet.getLastRow() <= 1);

  if (useFallback) {
    // Fallback: baca dari Ticket_Fields dan return sebagai format Form_Settings
    if (!tfSheet || tfSheet.getLastRow() <= 1) return [];
    var tfData = tfSheet.getDataRange().getValues();
    var tfMap  = getColumnMap(tfSheet);
    var tfResult = [];
    for (var i = 1; i < tfData.length; i++) {
      var ft = String(tfData[i][tfMap['field_type']] || 'text');
      var divisi = String(tfData[i][tfMap['divisi']] || '');
      var namaPengajuan = String(tfData[i][tfMap['nama_pengajuan']] || '');
      if (filterUnit && divisi.toLowerCase() !== String(filterUnit).toLowerCase()) continue;
      if (filterKategori && namaPengajuan.toLowerCase() !== String(filterKategori).toLowerCase()) continue;
      tfResult.push({
        id_setting:         'TF-' + (i + 1),
        nama_pengajuan:     namaPengajuan,
        divisi:             divisi,
        field_name:         String(tfData[i][tfMap['field_name']] || ''),
        field_label:        String(tfData[i][tfMap['field_label']] || ''),
        field_type:         ft,
        required:           Number(tfData[i][tfMap['required']]) === 1,
        options:            String(tfData[i][tfMap['options']] || ''),
        urutan:             Number(tfData[i][tfMap['urutan']]) || 0,
        field_section:      String(tfData[i][tfMap['field_section']] || 'detail'),
        terkait_inventaris: ft.indexOf('inventory') !== -1,
        id_alat_referensi:  '',
        last_modified_by:   'System',
        last_modified_at:   '',
        depends_on_field:   tfMap['depends_on_field'] !== undefined ? String(tfData[i][tfMap['depends_on_field']] || '') : '',
        depends_on_value:   tfMap['depends_on_value'] !== undefined ? String(tfData[i][tfMap['depends_on_value']] || '') : ''
      });
    }
    tfResult.sort(function(a, b) {
      if (a.divisi !== b.divisi) return a.divisi.localeCompare(b.divisi);
      if (a.nama_pengajuan !== b.nama_pengajuan) return a.nama_pengajuan.localeCompare(b.nama_pengajuan);
      return a.urutan - b.urutan;
    });
    return tfResult;
  }

  // Baca dari Form_Settings (mode utama)
  var data = fsSheet.getDataRange().getValues();
  var map  = getColumnMap(fsSheet);
  var result = [];
  var existingFieldNames = {};

  for (var i = 1; i < data.length; i++) {
    if (String(data[i][map['status']]).toLowerCase() !== 'active') continue;
    var divisi = String(data[i][map['divisi']] || '');
    var namaPengajuan = String(data[i][map['nama_pengajuan']] || '');
    if (filterUnit && divisi.toLowerCase() !== String(filterUnit).toLowerCase()) continue;
    if (filterKategori && namaPengajuan.toLowerCase() !== String(filterKategori).toLowerCase()) continue;

    var fn = String(data[i][map['field_name']] || '');
    existingFieldNames[namaPengajuan + '|' + fn] = true;

    result.push({
      id_setting:         String(data[i][map['id_setting']] || ''),
      nama_pengajuan:     namaPengajuan,
      divisi:             divisi,
      field_name:         fn,
      field_label:        String(data[i][map['field_label']] || ''),
      field_type:         String(data[i][map['field_type']] || 'text'),
      required:           Number(data[i][map['required']]) === 1,
      options:            String(data[i][map['options']] || ''),
      urutan:             Number(data[i][map['urutan']]) || 0,
      field_section:      String(data[i][map['field_section']] || 'detail'),
      terkait_inventaris: Number(data[i][map['terkait_inventaris']]) === 1,
      id_alat_referensi:  String(data[i][map['id_alat_referensi']] || ''),
      last_modified_by:   String(data[i][map['last_modified_by']] || ''),
      last_modified_at:   safeDateFormat(data[i][map['last_modified_at']]),
      depends_on_field:   map['depends_on_field'] !== undefined ? String(data[i][map['depends_on_field']] || '') : '',
      depends_on_value:   map['depends_on_value'] !== undefined ? String(data[i][map['depends_on_value']] || '') : ''
    });
  }

  // Auto-sync: tambahkan field dari Ticket_Fields yang belum ada di Form_Settings
  if (tfSheet && tfSheet.getLastRow() > 1) {
    var tfData = tfSheet.getDataRange().getValues();
    var tfMap  = getColumnMap(tfSheet);
    for (var j = 1; j < tfData.length; j++) {
      var tfNamaPengajuan = String(tfData[j][tfMap['nama_pengajuan']] || '');
      var tfFieldName     = String(tfData[j][tfMap['field_name']] || '');
      var tfDivisi        = String(tfData[j][tfMap['divisi']] || '');
      var tfFt            = String(tfData[j][tfMap['field_type']] || 'text');
      var key             = tfNamaPengajuan + '|' + tfFieldName;
      if (!existingFieldNames[key]) {
        if (filterUnit && tfDivisi.toLowerCase() !== String(filterUnit).toLowerCase()) continue;
        if (filterKategori && tfNamaPengajuan.toLowerCase() !== String(filterKategori).toLowerCase()) continue;
        // Auto-append ke Form_Settings agar sinkron
        var depField = tfMap['depends_on_field'] !== undefined ? String(tfData[j][tfMap['depends_on_field']] || '') : '';
        var depValue = tfMap['depends_on_value'] !== undefined ? String(tfData[j][tfMap['depends_on_value']] || '') : '';
        try {
          fsSheet.appendRow([
            'FS-' + Date.now() + '-' + j,
            tfNamaPengajuan, tfDivisi, tfFieldName,
            String(tfData[j][tfMap['field_label']] || ''),
            tfFt,
            Number(tfData[j][tfMap['required']]) || 0,
            String(tfData[j][tfMap['options']] || ''),
            Number(tfData[j][tfMap['urutan']]) || 0,
            String(tfData[j][tfMap['field_section']] || 'detail'),
            tfFt.indexOf('inventory') !== -1 ? 1 : 0, '', 'System Sync', new Date(), 'Active',
            depField,
            depValue
          ]);
        } catch(syncErr) { Logger.log('Auto-sync error: ' + syncErr); }
        result.push({
          id_setting:         'FS-' + Date.now() + '-' + j,
          nama_pengajuan:     tfNamaPengajuan,
          divisi:             tfDivisi,
          field_name:         tfFieldName,
          field_label:        String(tfData[j][tfMap['field_label']] || ''),
          field_type:         tfFt,
          required:           Number(tfData[j][tfMap['required']]) === 1,
          options:            String(tfData[j][tfMap['options']] || ''),
          urutan:             Number(tfData[j][tfMap['urutan']]) || 0,
          field_section:      String(tfData[j][tfMap['field_section']] || 'detail'),
          terkait_inventaris: tfFt.indexOf('inventory') !== -1,
          id_alat_referensi:  '',
          last_modified_by:   'System Sync',
          last_modified_at:   '',
          depends_on_field:   depField,
          depends_on_value:   depValue
        });
      }
    }
  }

  result.sort(function(a, b) {
    if (a.divisi !== b.divisi) return a.divisi.localeCompare(b.divisi);
    if (a.nama_pengajuan !== b.nama_pengajuan) return a.nama_pengajuan.localeCompare(b.nama_pengajuan);
    return a.urutan - b.urutan;
  });
  return result;
}

function saveFormSetting(payload, adminName, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat mengelola form settings.' };
  }
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('Form_Settings');
    if (!sheet) return { success: false, message: 'Sheet Form_Settings tidak ditemukan' };

    var requiredCols = [
      'id_setting', 'nama_pengajuan', 'divisi', 'field_name', 'field_label',
      'field_type', 'required', 'options', 'urutan', 'field_section',
      'terkait_inventaris', 'id_alat_referensi', 'last_modified_by',
      'last_modified_at', 'status', 'depends_on_field', 'depends_on_value'
    ];
    ensureColumns(sheet, requiredCols);
    var map = getColumnMap(sheet);

    var isInv = String(payload.field_type).indexOf('inventory') !== -1;
    var now = new Date();
    var admin = adminName || 'Admin';

    var idSetting = payload.id_setting;
    var isFallback = idSetting && idSetting.toString().indexOf('TF-') === 0;
    var isTemp = idSetting && idSetting.toString().indexOf('FS-TEMP-') === 0;

    var idToUse = (idSetting && !isFallback && !isTemp) ? idSetting : ('FS-' + Date.now());

    var fieldValues = {
      'id_setting': idToUse,
      'nama_pengajuan': payload.nama_pengajuan,
      'divisi': payload.divisi || '',
      'field_name': payload.field_name,
      'field_label': payload.field_label,
      'field_type': payload.field_type,
      'required': payload.required ? 1 : 0,
      'options': payload.options || '',
      'urutan': payload.urutan || 1,
      'field_section': payload.field_section || 'detail',
      'terkait_inventaris': isInv ? 1 : 0,
      'id_alat_referensi': isInv ? payload.field_name : '',
      'last_modified_by': admin,
      'last_modified_at': now,
      'status': 'Active',
      'depends_on_field': payload.depends_on_field || '',
      'depends_on_value': payload.depends_on_value || ''
    };

    var numColumns = sheet.getLastColumn() || requiredCols.length;
    var rowData = new Array(numColumns);
    for (var colIdx = 0; colIdx < numColumns; colIdx++) {
      rowData[colIdx] = '';
    }

    for (var key in fieldValues) {
      if (map[key] !== undefined) {
        rowData[map[key]] = fieldValues[key];
      }
    }

    if (idSetting && !isFallback && !isTemp) {
      // Update existing row
      var data = sheet.getDataRange().getValues();
      var updated = false;
      for (var i = 1; i < data.length; i++) {
        if (String(data[i][map['id_setting']]) === String(idSetting)) {
          sheet.getRange(i + 1, 1, 1, rowData.length).setValues([rowData]);
          updated = true;
          if (isInv) {
            tulisJurnalBarang('', payload.field_label, 'Edit Form Inventaris', 0, 0, 0,
              'Field form "' + payload.field_label + '" untuk "' + payload.nama_pengajuan + '" diperbarui oleh ' + admin, admin);
          }
          break;
        }
      }
      if (!updated) return { success: false, message: 'ID Setting tidak ditemukan.' };
    } else {
      // Insert new row into Form_Settings
      sheet.appendRow(rowData);
      if (isInv) {
        tulisJurnalBarang('', payload.field_label, 'Tambah Form Inventaris', 0, 0, 0,
          'Field form baru "' + payload.field_label + '" untuk "' + payload.nama_pengajuan + '" ditambahkan oleh ' + admin, admin);
      }
    }

    // Sync ke Ticket_Fields untuk backward compatibility
    syncFormSettingToTicketFields(payload);
    return { success: true };
  } catch (e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function deleteFormSetting(idSetting, adminName, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat menghapus form settings.' };
  }
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var admin = adminName || 'Admin';
    var isFallback = idSetting && idSetting.toString().indexOf('TF-') === 0;

    if (isFallback) {
      // It's a fallback setting. It only exists in Ticket_Fields.
      var rowIdx = parseInt(idSetting.replace('TF-', ''), 10);
      var tfSheet = ss.getSheetByName('Ticket_Fields');
      if (tfSheet) {
        var tfData = tfSheet.getDataRange().getValues();
        var tfMap = getColumnMap(tfSheet);
        if (rowIdx > 0 && rowIdx <= tfData.length) {
          var rowData = tfData[rowIdx - 1];
          var fieldName = String(rowData[tfMap['field_name']]);
          var fieldLabel = String(rowData[tfMap['field_label']]);
          var namaPengajuan = String(rowData[tfMap['nama_pengajuan']]);
          var divisi = String(rowData[tfMap['divisi']]);
          var fieldType = String(rowData[tfMap['field_type']]);
          var isInv = fieldType.indexOf('inventory') !== -1;

          // Delete from Ticket_Fields
          tfSheet.deleteRow(rowIdx);

          // Write inactive/soft-deleted setting to Form_Settings to prevent it from ever being recreated or synced
          var fsSheet = ss.getSheetByName('Form_Settings');
          if (fsSheet) {
            var fsMap = getColumnMap(fsSheet);
            var fsData = fsSheet.getDataRange().getValues();
            var foundFsIdx = -1;
            for (var fsi = 1; fsi < fsData.length; fsi++) {
              if (String(fsData[fsi][fsMap['field_name']]).toLowerCase() === fieldName.toLowerCase() &&
                  String(fsData[fsi][fsMap['nama_pengajuan']]).toLowerCase() === namaPengajuan.toLowerCase()) {
                foundFsIdx = fsi;
                break;
              }
            }

            var now = new Date();
            var newRow = [
              'FS-' + Date.now(),
              namaPengajuan,
              divisi,
              fieldName,
              fieldLabel,
              fieldType,
              0, // required
              '', // options
              0, // urutan
              'detail', // field_section
              isInv ? 1 : 0,
              isInv ? fieldName : '',
              admin,
              now,
              'Inactive',
              '', // depends_on_field
              ''  // depends_on_value
            ];

            if (foundFsIdx !== -1) {
              fsSheet.getRange(foundFsIdx + 1, fsMap['status'] + 1).setValue('Inactive');
              fsSheet.getRange(foundFsIdx + 1, fsMap['last_modified_by'] + 1).setValue(admin);
              fsSheet.getRange(foundFsIdx + 1, fsMap['last_modified_at'] + 1).setValue(now);
            } else {
              fsSheet.appendRow(newRow);
            }
          }

          if (isInv) {
            tulisJurnalBarang('', fieldLabel, 'Hapus Form Inventaris', 0, 0, 0,
              'Field form "' + fieldLabel + '" untuk "' + namaPengajuan + '" dinonaktifkan oleh ' + admin, admin);
          }
          return { success: true };
        }
      }
      return { success: false, message: 'Row fallback tidak ditemukan di Ticket_Fields' };
    } else {
      var sheet = ss.getSheetByName('Form_Settings');
      if (!sheet) return { success: false, message: 'Sheet Form_Settings tidak ditemukan' };

      var data = sheet.getDataRange().getValues();
      var map  = getColumnMap(sheet);

      for (var i = 1; i < data.length; i++) {
        if (String(data[i][map['id_setting']]) === String(idSetting)) {
          var fieldName    = String(data[i][map['field_name']]);
          var fieldLabel   = String(data[i][map['field_label']]);
          var namaPengajuan = String(data[i][map['nama_pengajuan']]);
          var isInv        = Number(data[i][map['terkait_inventaris']]) === 1;

          // Soft delete: set status Inactive
          sheet.getRange(i + 1, map['status'] + 1).setValue('Inactive');
          sheet.getRange(i + 1, map['last_modified_by'] + 1).setValue(admin);
          sheet.getRange(i + 1, map['last_modified_at'] + 1).setValue(new Date());

          // Also delete from Ticket_Fields to ensure it disappears from public form and won't be auto-synced back
          try {
            var tfSheet = ss.getSheetByName('Ticket_Fields');
            if (tfSheet) {
              var tfData = tfSheet.getDataRange().getValues();
              var tfMap  = getColumnMap(tfSheet);
              for (var tfIdx = tfData.length - 1; tfIdx >= 1; tfIdx--) {
                if (String(tfData[tfIdx][tfMap['field_name']]).toLowerCase() === String(fieldName).toLowerCase() &&
                    String(tfData[tfIdx][tfMap['nama_pengajuan']]).toLowerCase() === String(namaPengajuan).toLowerCase()) {
                  tfSheet.deleteRow(tfIdx + 1);
                  break;
                }
              }
            }
          } catch(tfErr) {
            Logger.log('Gagal hapus dari Ticket_Fields: ' + tfErr.toString());
          }

          if (isInv) {
            tulisJurnalBarang('', fieldLabel, 'Hapus Form Inventaris', 0, 0, 0,
              'Field form "' + fieldLabel + '" untuk "' + namaPengajuan + '" dinonaktifkan oleh ' + admin, admin);
          }
          return { success: true };
        }
      }
      return { success: false, message: 'Setting tidak ditemukan' };
    }
  } catch (e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function syncFormSettingToTicketFields(payload) {
  var tfSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Ticket_Fields');
  if (!tfSheet) return;
  var tfData = tfSheet.getDataRange().getValues();
  var tfMap  = getColumnMap(tfSheet);
  var found  = false;

  for (var i = 1; i < tfData.length; i++) {
    if (String(tfData[i][tfMap['field_name']]).toLowerCase()     === String(payload.field_name).toLowerCase() &&
        String(tfData[i][tfMap['nama_pengajuan']]).toLowerCase() === String(payload.nama_pengajuan).toLowerCase()) {
      tfSheet.getRange(i + 1, tfMap['field_label']    + 1).setValue(payload.field_label);
      tfSheet.getRange(i + 1, tfMap['field_type']     + 1).setValue(payload.field_type);
      tfSheet.getRange(i + 1, tfMap['required']       + 1).setValue(payload.required ? 1 : 0);
      tfSheet.getRange(i + 1, tfMap['options']        + 1).setValue(payload.options || '');
      tfSheet.getRange(i + 1, tfMap['urutan']         + 1).setValue(payload.urutan || 1);
      tfSheet.getRange(i + 1, tfMap['field_section']  + 1).setValue(payload.field_section || 'detail');
      if (tfMap['depends_on_field'] !== undefined) tfSheet.getRange(i + 1, tfMap['depends_on_field'] + 1).setValue(payload.depends_on_field || '');
      if (tfMap['depends_on_value'] !== undefined) tfSheet.getRange(i + 1, tfMap['depends_on_value'] + 1).setValue(payload.depends_on_value || '');
      found = true;
      break;
    }
  }

  if (!found) {
    var tfRequiredCols = [
      'id', 'nama_pengajuan', 'divisi', 'field_name', 'field_label',
      'field_type', 'required', 'options', 'urutan', 'field_section',
      'depends_on_field', 'depends_on_value'
    ];
    ensureColumns(tfSheet, tfRequiredCols);
    tfMap = getColumnMap(tfSheet); // refresh map after ensureColumns

    var numTfCols = tfSheet.getLastColumn() || tfRequiredCols.length;
    var tfRowData = new Array(numTfCols);
    for (var cIdx = 0; cIdx < numTfCols; cIdx++) {
      tfRowData[cIdx] = '';
    }

    var tfValues = {
      'id': 1,
      'nama_pengajuan': payload.nama_pengajuan,
      'divisi': payload.divisi || '',
      'field_name': payload.field_name,
      'field_label': payload.field_label,
      'field_type': payload.field_type,
      'required': payload.required ? 1 : 0,
      'options': payload.options || '',
      'urutan': payload.urutan || 1,
      'field_section': payload.field_section || 'detail',
      'depends_on_field': payload.depends_on_field || '',
      'depends_on_value': payload.depends_on_value || ''
    };

    for (var tfKey in tfValues) {
      if (tfMap[tfKey] !== undefined) {
        tfRowData[tfMap[tfKey]] = tfValues[tfKey];
      }
    }
    tfSheet.appendRow(tfRowData);
  }
}

// --- EXPORT FUNCTION ---
function exportTickets(type) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const fileId = ss.getId();
  const sheetName = 'Master_Tickets';
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) return { success: false, message: 'Sheet Master_Tickets tidak ditemukan' };
  const sheetId = sheet.getSheetId();
  let url = '';
  
  if (type === 'excel') {
    url = `https://docs.google.com/spreadsheets/d/${fileId}/export?format=xlsx&gid=${sheetId}`;
  } else if (type === 'pdf') {
    url = `https://docs.google.com/spreadsheets/d/${fileId}/export?format=pdf&size=A4&portrait=false&gid=${sheetId}`;
  }
  return { success: true, url: url };
}

// --- MODUL: PENGATURAN SLA & KALENDER HARI LIBUR (FASE 3) ---

function saveSubCategorySla(id, slaHari, currentUserRole) {
  if (currentUserRole !== 'Admin') {
    return { status: 'error', message: 'Akses Ditolak: Hanya Admin yang dapat mengubah durasi SLA' };
  }
  const slaHariVal = Number(slaHari);
  if (isNaN(slaHariVal) || slaHariVal < 1) {
    return { status: 'error', message: 'Durasi SLA minimal 1 hari kerja' };
  }
  
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('Sub_Categories');
    if (!sheet) return { status: 'error', message: 'Sheet Sub_Categories tidak ditemukan' };
    
    const data = sheet.getDataRange().getValues();
    const map = getColumnMap(sheet);
    let rowIdx = -1;
    let subName = '';
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][map['id']]) === String(id)) {
        rowIdx = i + 1;
        subName = data[i][map['nama']];
        break;
      }
    }
    
    if (rowIdx === -1) {
      return { status: 'error', message: 'Sub-kategori tidak ditemukan' };
    }
    
    sheet.getRange(rowIdx, map['sla_hari'] + 1).setValue(slaHariVal);
    
    recalculateSlaForActiveTickets(subName);
    
    return { status: 'success', message: 'SLA sub-kategori berhasil diperbarui' };
  } catch(e) {
    return { status: 'error', message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function addWorkingDays(startDate, days) {
  if (!startDate) return null;
  const start = new Date(startDate);
  if (isNaN(start.getTime())) return null;
  
  const daysToAdd = Number(days);
  if (isNaN(daysToAdd) || daysToAdd <= 0) return start;
  
  let current = new Date(start.getTime());
  let added = 0;
  
  while (added < daysToAdd) {
    current.setDate(current.getDate() + 1);
    const day = current.getDay();
    if (day === 0 || day === 6) continue;
    added++;
  }
  return current;
}

function getWorkingDaysBetween(startDate, endDate) {
  if (!startDate || !endDate) return 0;
  const start = new Date(startDate);
  const end = new Date(endDate);
  if (isNaN(start.getTime()) || isNaN(end.getTime())) return 0;
  
  let count = 0;
  
  const current = new Date(start.getTime());
  current.setHours(0,0,0,0);
  const target = new Date(end.getTime());
  target.setHours(0,0,0,0);
  
  const isOverdue = current > target;
  
  if (isOverdue) {
    let temp = new Date(target.getTime());
    while (temp < current) {
      const day = temp.getDay();
      if (day !== 0 && day !== 6) {
        count--;
      }
      temp.setDate(temp.getDate() + 1);
    }
    return count;
  } else {
    let temp = new Date(current.getTime());
    while (temp < target) {
      temp.setDate(temp.getDate() + 1);
      const day = temp.getDay();
      if (day !== 0 && day !== 6) {
        count++;
      }
    }
    return count;
  }
}

function recalculateSlaForActiveTickets(subLayanan) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const ticketSheet = ss.getSheetByName('Master_Tickets');
  if (!ticketSheet) return;
  
  const ticketData = ticketSheet.getDataRange().getValues();
  if (ticketData.length <= 1) return;
  const ticketMap = getColumnMap(ticketSheet);
  
  const subcatSheet = ss.getSheetByName('Sub_Categories');
  if (!subcatSheet) return;
  const subcatData = subcatSheet.getDataRange().getValues();
  const subcatMap = getColumnMap(subcatSheet);
  
  const slaMap = {};
  for (let s = 1; s < subcatData.length; s++) {
    const sName = subcatData[s][subcatMap['nama']];
    const sSla = Number(subcatData[s][subcatMap['sla_hari']]) || 3;
    slaMap[sName] = sSla;
  }
  
  for (let i = 1; i < ticketData.length; i++) {
    const status = ticketData[i][ticketMap['status']];
    if (status === 'Solved' || status === 'Reject' || status === 'Batal') continue;
    
    const ticketSubLayanan = ticketData[i][ticketMap['sub_layanan']];
    if (subLayanan && ticketSubLayanan !== subLayanan) continue;
    
    const createdAtVal = ticketData[i][ticketMap['created_at']];
    if (!createdAtVal) continue;
    const createdAt = new Date(createdAtVal);
    
    const slaHari = slaMap[ticketSubLayanan] || 3;
    const newDeadline = addWorkingDays(createdAt, slaHari);
    if (newDeadline) {
      ticketSheet.getRange(i + 1, ticketMap['sla_hari'] + 1).setValue(slaHari);
      ticketSheet.getRange(i + 1, ticketMap['sla_deadline'] + 1).setValue(newDeadline);
      
      const now = new Date();
      const diffWorkingDays = getWorkingDaysBetween(now, newDeadline);
      let newSlaStatus = 'On Time';
      if (diffWorkingDays < 0) {
        newSlaStatus = 'Overdue';
      } else if (diffWorkingDays <= 1) {
        newSlaStatus = 'Warning';
      }
      ticketSheet.getRange(i + 1, ticketMap['sla_status'] + 1).setValue(newSlaStatus);
    }
  }
}

function isSlaNotificationSent(ticketId, threshold) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('SLA_Notif_Log');
  if (!sheet) return false;
  
  const data = sheet.getDataRange().getValues();
  if (data.length <= 1) return false;
  const map = getColumnMap(sheet);
  
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][map['ticket_id']]) === String(ticketId) && 
        String(data[i][map['threshold']]) === String(threshold)) {
      return true;
    }
  }
  return false;
}

function logSlaNotification(ticketId, threshold) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName('SLA_Notif_Log');
  if (!sheet) {
    sheet = ss.insertSheet('SLA_Notif_Log');
    sheet.appendRow(['id', 'ticket_id', 'threshold', 'sent_at', 'status']);
    sheet.setFrozenRows(1);
  }
  const newId = String(Date.now() + Math.floor(Math.random() * 1000));
  sheet.appendRow([newId, ticketId, threshold, new Date(), 'Sent']);
}
