        fasilitas: data[i][map['fasilitas']],
        status: data[i][map['status']]
      });
    }
  }
  return result;
}

function checkScheduleConflict(idRuangan, tgl, jamMulai, jamSelesai) {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Room_Bookings');
  if (!sheet || sheet.getLastRow() <= 1) return { conflict: false };
  var data = sheet.getDataRange().getValues();
  var map = getColumnMap(sheet);
  for (var i = 1; i < data.length; i++) {
    var bStatus = String(data[i][map['status']] || '').toLowerCase();
    if (bStatus === 'cancelled' || bStatus === 'batal' || bStatus === 'reject') continue;
    if (String(data[i][map['id_ruangan']]) === String(idRuangan)) {
      var bTgl = data[i][map['tgl_pakai']];
      var bTglStr = '';
      if (bTgl instanceof Date) {
        bTglStr = Utilities.formatDate(bTgl, Session.getScriptTimeZone(), 'yyyy-MM-dd');
      } else {
        bTglStr = String(bTgl);
      }
      if (bTglStr === String(tgl)) {
        var bStart = String(data[i][map['jam_mulai']]);
        var bEnd = String(data[i][map['jam_selesai']]);
        if (jamMulai < bEnd && jamSelesai > bStart) {
          return {
            conflict: true,
            message: 'Ruangan sudah di-booking pada ' + tgl + ' pukul ' + bStart + ' - ' + bEnd + ' (' + String(data[i][map['nama_pemesan']] || 'N/A') + ')'
          };
        }
      }
    }
  }
  return { conflict: false };
}

function checkZoomScheduleConflict(tgl, jamMulai, jamSelesai) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ticketSheet = ss.getSheetByName('Master_Tickets');
  var detailSheet = ss.getSheetByName('Ticket_Details');
  if (!ticketSheet || ticketSheet.getLastRow() <= 1) return { conflict: false };
  if (!detailSheet || detailSheet.getLastRow() <= 1) return { conflict: false };

  var tData = ticketSheet.getDataRange().getValues();
  var tMap = getColumnMap(ticketSheet);

  var dData = detailSheet.getDataRange().getValues();
  var dMap = getColumnMap(detailSheet);

  // 1. Dapatkan daftar ID tiket aktif yang memesan Zoom
  var activeZoomTicketIds = [];
  for (var i = 1; i < tData.length; i++) {
    var sub = String(tData[i][tMap['sub_layanan']]);
    var status = String(tData[i][tMap['status']]).toLowerCase();
    if (sub === 'Penggunaan Link Zoom' && status !== 'reject' && status !== 'batal' && status !== 'cancelled') {
      activeZoomTicketIds.push(String(tData[i][tMap['ticket_id']]));
    }
  }

  if (activeZoomTicketIds.length === 0) return { conflict: false };

  // 2. Petakan detail untuk setiap tiket tersebut
  var zoomBookings = {};
  for (var i = 1; i < tData.length; i++) {
    var tid = String(tData[i][tMap['ticket_id']]);
    if (activeZoomTicketIds.indexOf(tid) !== -1) {
      zoomBookings[tid] = {
        nama_pemesan: tData[i][tMap['nama']],
        tgl_meeting: '',
        jam_mulai_zoom: '',
        jam_selesai_zoom: ''
      };
    }
  }

  for (var j = 1; j < dData.length; j++) {
    var tid = String(dData[j][dMap['ticket_id']]);
    if (zoomBookings[tid]) {
      var fieldName = String(dData[j][dMap['field_name']]);
      var val = String(dData[j][dMap['field_value']]);
      
      if (fieldName === 'tgl_meeting') {
        if (val.indexOf('GMT') !== -1 || val.indexOf('00:00:00') !== -1) {
          try {
            var dateObj = new Date(val);
            val = Utilities.formatDate(dateObj, Session.getScriptTimeZone(), 'yyyy-MM-dd');
          } catch(e) {}
        }
        zoomBookings[tid].tgl_meeting = val;
      } else if (fieldName === 'jam_mulai_zoom') {
        zoomBookings[tid].jam_mulai_zoom = val;
      } else if (fieldName === 'jam_selesai_zoom') {
        zoomBookings[tid].jam_selesai_zoom = val;
      }
    }
  }

  // 3. Bandingkan dengan parameter input
  var inputTglStr = String(tgl);
  if (tgl instanceof Date) {
    inputTglStr = Utilities.formatDate(tgl, Session.getScriptTimeZone(), 'yyyy-MM-dd');
  }

  for (var tid in zoomBookings) {
    var booking = zoomBookings[tid];
    if (booking.tgl_meeting === inputTglStr && booking.jam_mulai_zoom && booking.jam_selesai_zoom) {
      if (jamMulai < booking.jam_selesai_zoom && jamSelesai > booking.jam_mulai_zoom) {
        return {
          conflict: true,
          message: 'Akun Zoom berbayar sudah di-booking pada tanggal ' + inputTglStr + ' pukul ' + booking.jam_mulai_zoom + ' - ' + booking.jam_selesai_zoom + ' (' + booking.nama_pemesan + ')'
        };
      }
    }
  }

  return { conflict: false };
}

function saveRoomBooking(ticketId, namaPemesan, idRuangan, tgl, jamMulai, jamSelesai, keperluan) {
