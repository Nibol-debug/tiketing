function doGet(e) {
  var view = e && e.parameter && e.parameter.view;
  var templateName = (view === 'display') ? 'Display' : 'Index';
  var template = HtmlService.createTemplateFromFile(templateName);
  // Inject URL /exec ke template agar bisa diakses frontend tanpa OAuth
  try {
    template.execUrl = ScriptApp.getService().getUrl();
  } catch(err) {
    template.execUrl = '';
  }
  return template
    .evaluate()
    .setTitle(templateName === 'Display' ? 'Lobby Display Monitor' : 'Ticketing & Request System')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function ensureColumn(sheet, colName) {
  if (!sheet) return;
  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn() || 1).getValues()[0];
  if (headers.indexOf(colName) === -1) {
    sheet.getRange(1, headers.length + 1).setValue(colName);
  }
}

function ensureColumns(sheet, requiredCols) {
  if (!sheet) return;
  requiredCols.forEach(col => {
    ensureColumn(sheet, col);
  });
}

function renameColumnIfExist(sheet, oldName, newName) {
  if (!sheet) return;
  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn() || 1).getValues()[0];
  for (var i = 0; i < headers.length; i++) {
    if (String(headers[i]).toLowerCase().trim() === oldName.toLowerCase()) {
      sheet.getRange(1, i + 1).setValue(newName);
      return;
    }
  }
}

function normalizePhone(phone) {
  if (!phone) return '';
  let cleaned = String(phone).replace(/\D/g, '');
  if (cleaned.startsWith('0')) {
    cleaned = '62' + cleaned.substring(1);
  } else if (cleaned.startsWith('8')) {
    cleaned = '62' + cleaned;
  }
  return cleaned;
}

function deduplicateRequesters(sheet) {
  if (!sheet) return;
  const data = sheet.getDataRange().getValues();
  if (data.length <= 2) return;
  
  const map = getColumnMap(sheet);
  const headers = data[0];
  const merged = {};
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const rawWa = String(row[map['whatsapp']] || '').trim();
    const rawEmail = String(row[map['email']] || '').trim();
    const name = String(row[map['nama']] || '').trim();
    const totalReq = Number(row[map['total_request']]) || 0;
    const lastReq = row[map['last_request']];
    
    let key = '';
    let isEmail = false;
    
    if (rawWa.includes('@')) {
      key = rawWa.toLowerCase();
      isEmail = true;
    } else if (rawEmail.includes('@')) {
      key = rawEmail.toLowerCase();
      isEmail = true;
    } else {
      key = normalizePhone(rawWa);
    }
    
    if (!key) continue;
    
    if (!merged[key]) {
      merged[key] = {
        whatsapp: isEmail ? '' : rawWa,
        email: isEmail ? key : rawEmail,
        nama: name,
        total_request: totalReq,
        last_request: lastReq
      };
    } else {
      const existing = merged[key];
      if (name) existing.nama = name;
      existing.total_request += totalReq;
      if (lastReq) {
        if (!existing.last_request) {
          existing.last_request = lastReq;
        } else {
          const d1 = new Date(existing.last_request);
          const d2 = new Date(lastReq);
          if (d2 > d1) existing.last_request = lastReq;
        }
      }
      if (!isEmail) {
        if (rawWa && !existing.whatsapp) existing.whatsapp = rawWa;
        if (rawEmail && !existing.email) existing.email = rawEmail;
      } else {
        if (!rawWa.includes('@') && rawWa) existing.whatsapp = rawWa;
      }
    }
  }
  
  if (sheet.getLastRow() > 1) {
    sheet.getRange(2, 1, sheet.getLastRow() - 1, sheet.getLastColumn()).clearContent();
  }
  
  const rowsToAppend = Object.keys(merged).map(key => {
    const item = merged[key];
    const row = [];
    headers.forEach(h => {
      const colName = String(h).toLowerCase().trim();
      if (colName === 'whatsapp') row.push(item.whatsapp);
      else if (colName === 'email') row.push(item.email);
      else if (colName === 'nama') row.push(item.nama);
      else if (colName === 'total_request') row.push(item.total_request);
      else if (colName === 'last_request') row.push(item.last_request);
      else row.push('');
    });
    return row;
  });
  
  if (rowsToAppend.length > 0) {
    sheet.getRange(2, 1, rowsToAppend.length, headers.length).setValues(rowsToAppend);
  }
}

function populateRequestersFromTickets(sheetReq) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheetTickets = ss.getSheetByName('Master_Tickets');
  if (!sheetTickets || sheetTickets.getLastRow() <= 1) return;
  
  const ticketsData = sheetTickets.getDataRange().getValues();
  const mapTickets = getColumnMap(sheetTickets);
  
  const requesters = {};
  
  const waCol = mapTickets['whatsapp'] !== undefined ? mapTickets['whatsapp'] : mapTickets['kontak'];
  const emailCol = mapTickets['email'];
  const namaCol = mapTickets['nama'];
  const createdCol = mapTickets['created_at'];
  
  for (let i = 1; i < ticketsData.length; i++) {
    const row = ticketsData[i];
    const rawWa = waCol !== undefined ? String(row[waCol] || '').trim() : '';
    const rawEmail = emailCol !== undefined ? String(row[emailCol] || '').trim() : '';
    const name = namaCol !== undefined ? String(row[namaCol] || '').trim() : '';
    const createdAt = createdCol !== undefined ? row[createdCol] : null;
    
    let key = '';
    let isEmail = false;
    
    if (rawWa.includes('@')) {
      key = rawWa.toLowerCase();
      isEmail = true;
    } else if (rawEmail.includes('@')) {
      key = rawEmail.toLowerCase();
      isEmail = true;
    } else {
      key = normalizePhone(rawWa);
    }
    
    if (!key) continue;
    
    if (!requesters[key]) {
      requesters[key] = {
        whatsapp: isEmail ? '' : rawWa,
        email: isEmail ? key : rawEmail,
        nama: name,
        total_request: 1,
        last_request: createdAt
      };
    } else {
      const existing = requesters[key];
      if (name && !existing.nama) existing.nama = name;
      existing.total_request += 1;
      if (createdAt) {
        if (!existing.last_request) {
          existing.last_request = createdAt;
        } else {
          const d1 = new Date(existing.last_request);
          const d2 = new Date(createdAt);
          if (d2 > d1) existing.last_request = createdAt;
        }
      }
      if (!isEmail) {
        if (rawWa && !existing.whatsapp) existing.whatsapp = rawWa;
        if (rawEmail && !existing.email) existing.email = rawEmail;
      } else {
        if (!rawWa.includes('@') && rawWa) existing.whatsapp = rawWa;
      }
    }
  }
  
  const headers = sheetReq.getRange(1, 1, 1, sheetReq.getLastColumn()).getValues()[0];
  const rowsToAppend = Object.keys(requesters).map(key => {
    const item = requesters[key];
    const row = [];
    headers.forEach(h => {
      const colName = String(h).toLowerCase().trim();
      if (colName === 'whatsapp') row.push(item.whatsapp);
      else if (colName === 'email') row.push(item.email);
      else if (colName === 'nama') row.push(item.nama);
      else if (colName === 'total_request') row.push(item.total_request);
      else if (colName === 'last_request') row.push(item.last_request);
      else row.push('');
    });
    return row;
  });
  
  if (rowsToAppend.length > 0) {
    sheetReq.getRange(2, 1, rowsToAppend.length, headers.length).setValues(rowsToAppend);
  }
}

