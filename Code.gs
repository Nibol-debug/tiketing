function getAdminUsers(currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_admin')) {
    throw new Error('Akses Ditolak: Hanya Admin yang dapat melihat daftar pengguna admin.');
  }
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
  if (!sheet || sheet.getLastRow() <= 1) return [];
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const result = [];
  
  for (let i = 1; i < data.length; i++) {
    result.push({
      username: data[i][map['username']],
      fullname: data[i][map['fullname']],
      role: data[i][map['role']]
    });
  }
  return result;
}

function saveAdminUser(payload, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_admin')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat mengelola pengguna' };
  }
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
    const data = sheet.getDataRange().getValues();
    const map = getColumnMap(sheet);
    
    let isEdit = false;
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][map['username']]).trim().toLowerCase() === String(payload.username).trim().toLowerCase()) {
        sheet.getRange(i + 1, map['fullname'] + 1).setValue(payload.fullname);
        sheet.getRange(i + 1, map['role'] + 1).setValue(payload.role);
        if (payload.password) {
          sheet.getRange(i + 1, map['password'] + 1).setValue(hashPassword(payload.password));
        }
        isEdit = true;
        break;
      }
    }
    
    if (!isEdit) {
      if(!payload.password) return { success: false, message: 'Password wajib diisi untuk user baru' };
      sheet.appendRow([payload.username, hashPassword(payload.password), payload.fullname, payload.role]);
    }
    
    return { success: true };
  } catch(e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function deleteAdminUser(username, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_admin')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat menghapus pengguna' };
  }
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
    const data = sheet.getDataRange().getValues();
    const map = getColumnMap(sheet);
    
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][map['username']]).trim().toLowerCase() === String(username).trim().toLowerCase()) {
        sheet.deleteRow(i + 1);
        return { success: true };
      }
    }
    return { success: false, message: 'User tidak ditemukan' };
  } catch(e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function getAlatNamesArray(namaAlatStr) {
  if (!namaAlatStr) return [];
  return namaAlatStr.split(',').map(function(s) { return s.trim(); }).filter(function(s) { return s.length > 0; });
}

// --- CRUD & OPERATIONS TICKET ---
function submitTicket(payload) {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    
    if(!payload.nama || !payload.whatsapp || !payload.kategori || !payload.deskripsi) {
      return { success: false, message: 'Semua field wajib diisi (WhatsApp wajib)' };
    }

    // Backend Validations
    if (payload.sub_layanan === 'Pembuatan Video' && payload.custom_fields && payload.custom_fields.deadline) {
      var deadlineDate = new Date(payload.custom_fields.deadline);
      var today = new Date();
      today.setHours(0,0,0,0);
      var diffTime = deadlineDate.getTime() - today.getTime();
      var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
      if (diffDays < 3) {
        return { success: false, message: 'Pengerjaan video membutuhkan waktu minimal 3 hari kerja.' };
      }
    }

    if (payload.sub_layanan === 'Akun & Reset Sandi' && payload.custom_fields && payload.custom_fields.username) {
      var usernameVal = String(payload.custom_fields.username);
      if (usernameVal.indexOf(' ') !== -1) {
        return { success: false, message: 'Username tidak boleh mengandung spasi.' };
      }
    }

    if (payload.sub_layanan === 'Penggunaan Link Zoom' && payload.custom_fields && payload.custom_fields.tgl_meeting) {
      var tglVal = payload.custom_fields.tgl_meeting;
      var jamMulaiVal = payload.custom_fields.jam_mulai_zoom;
      var jamSelesaiVal = payload.custom_fields.jam_selesai_zoom;
      if (tglVal && jamMulaiVal && jamSelesaiVal) {
        var conflictResult = checkZoomScheduleConflict(tglVal, jamMulaiVal, jamSelesaiVal);
        if (conflictResult.conflict) {
          return { success: false, message: conflictResult.message };
        }
      }
    }

    // === VALIDASI BENTROK RUANGAN ===
    if (payload.sub_layanan === 'Penggunaan Ruangan' && payload.custom_fields) {
      var idRuangan = payload.custom_fields.id_ruangan;
      var tglPakai = payload.custom_fields.tgl_pakai;
      var jamMulai = payload.custom_fields.jam_mulai;
      var jamSelesai = payload.custom_fields.jam_selesai;
      if (idRuangan && tglPakai && jamMulai && jamSelesai) {
        var conflictResult = checkScheduleConflict(idRuangan, tglPakai, jamMulai, jamSelesai);
        if (conflictResult.conflict) {
          return { success: false, message: conflictResult.message };
        }
      }
    }

    // === VALIDASI BENTROK KENDARAAN ===
    if (payload.sub_layanan === 'Penggunaan Kendaraan' && payload.custom_fields) {
      var idKendaraan = payload.custom_fields.id_kendaraan;
      var tglBerangkat = payload.custom_fields.tgl_berangkat;
      var jamBerangkat = payload.custom_fields.jam_berangkat;
      var jamKembali = payload.custom_fields.jam_kembali;
      if (idKendaraan && tglBerangkat && jamBerangkat && jamKembali) {
        var conflictResult = checkVehicleConflict(idKendaraan, tglBerangkat, jamBerangkat, jamKembali);
        if (conflictResult.conflict) {
          return { success: false, message: conflictResult.message };
        }
      }
    }

    if (payload.sub_layanan === 'Peminjaman Alat' && payload.tgl_mulai_pinjam && payload.tgl_selesai_pinjam) {
      var tglPinjam = new Date(payload.tgl_mulai_pinjam);
      var tglSelesai = new Date(payload.tgl_selesai_pinjam);
      if (tglPinjam > tglSelesai) {
        return { success: false, message: 'Tanggal Pinjam harus lebih kecil atau sama dengan Tanggal Pengembalian.' };
      }
    }

    if (payload.sub_layanan === 'Request Akun Donasi' && payload.custom_fields && payload.custom_fields.nama_akun_donasi) {
      var namaAkunVal = String(payload.custom_fields.nama_akun_donasi);
      var regex = /^[a-zA-Z0-9 .\-]+$/;
      if (!regex.test(namaAkunVal)) {
        return { success: false, message: 'Nama Akun hanya boleh mengandung huruf, angka, spasi, titik, dan strip.' };
      }
    }

    // === VALIDASI SIM UNTUK KENDARAAN NON-TUGAS ===
    if (payload.sub_layanan === 'Penggunaan Kendaraan' && payload.custom_fields) {
      var keperluan = String(payload.custom_fields.keperluan_pengajuan || '').trim();
      var nomorSim = String(payload.custom_fields.nomor_sim || '').trim();
      
      if (keperluan === 'Non Tugas / Pribadi' && !nomorSim) {
        return { success: false, message: 'Untuk keperluan Non Tugas / Pribadi, Foto/Scan SIM WAJIB diunggah!' };
      }
    }

    // === VALIDASI DINAMIS FIELD BERKONDISI (BRANCHING) ===
    if (payload.sub_layanan && payload.custom_fields) {
      try {
        var fields = getTicketFields(payload.sub_layanan);
        for (var i = 0; i < fields.length; i++) {
          var f = fields[i];
          var val = payload.custom_fields[f.field_name];
          var valStr = String(val || '').trim();
          
          // Check dependency
          var isTriggered = true;
          if (f.depends_on_field) {
            var parentVal = String(payload.custom_fields[f.depends_on_field] || '').trim();
            if (parentVal !== String(f.depends_on_value).trim()) {
              isTriggered = false;
            }
          }
          
          if (isTriggered) {
            // Field aktif/terlihat
            // Skip validasi untuk field tipe 'info' (baca saja) dan 'checkbox' (persetujuan tunggal dihandle frontend)
            if (f.field_type === 'info') continue;
            if (f.required && !valStr) {
              return { success: false, message: '⚠️ Field "' + f.field_label + '" wajib diisi!' };
            }
          } else {
            // Dependency tidak terpenuhi -> Hapus isian agar tidak menyimpan data usang
            delete payload.custom_fields[f.field_name];
          }
        }
      } catch(validErr) {
        Logger.log('Gagal validasi dinamis: ' + validErr.toString());
      }
    }

    // Determine initial status and approval level
    var initialStatus = 'Open';
    var approvalLevel = 'Admin';
    if (payload.sub_layanan === 'Pengadaan Jasa & Barang' && payload.custom_fields) {
      var cost = Number(payload.custom_fields.estimasi_biaya) || 0;
      if (cost > 5000000) {
        initialStatus = 'Pending Approval Atasan';
        approvalLevel = 'Atasan';
      }
    }
    if (payload.sub_layanan === 'Data Sistem Penerimaan') {
      approvalLevel = 'Direksi';
    }

    const ticketId = 'TKT-' + Math.floor(1000 + Math.random() * 9000) + '-' + new Date().getTime().toString().slice(-4);
    const now = new Date();
    
    // === HITUNG SLA ===
    let slaHari = 3; // Default 3 hari kerja
    let slaDeadline = '';
    const sheetSubCats = ss.getSheetByName('Sub_Categories');
    if (sheetSubCats && payload.sub_layanan) {
      const subData = sheetSubCats.getDataRange().getValues();
      const subMap = getColumnMap(sheetSubCats);
      const subNameCol = subMap['nama_sub'] !== undefined ? subMap['nama_sub'] : subMap['nama'];
      const slaCol = subMap['sla_hari'];
      for (let s = 1; s < subData.length; s++) {
        if (subNameCol !== undefined && subData[s][subNameCol] === payload.sub_layanan) {
          if (slaCol !== undefined) {
            const valSla = Number(subData[s][slaCol]);
            if (!isNaN(valSla) && valSla > 0) {
              slaHari = valSla;
            }
          }
          break;
        }
      }
    }
    
    slaDeadline = addWorkingDays(now, slaHari);
    let slaStatus = 'On Time';
    
    function appendDynamicRow(sheetName, defaultVals) {
      const sheet = ss.getSheetByName(sheetName);
      if(!sheet) return;
      const map = getColumnMap(sheet);
      const headLen = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0].length;
      let newRow = new Array(headLen).fill('');
      
      for(let key in map) {
        if(defaultVals[key] !== undefined) newRow[map[key]] = defaultVals[key];
      }
      sheet.appendRow(newRow);
    }



    const rowData = {
      id: Date.now(),
      ticket_id: ticketId,
      nama: payload.nama,
      whatsapp: payload.whatsapp,
      email: payload.email || '',
      divisi_pengaju: payload.divisi_pengaju || '',
      sub_divisi_pengaju: payload.sub_divisi_pengaju || '',
      jabatan_pengaju: payload.jabatan_pengaju || '',
      kategori: payload.kategori,
      sub_layanan: payload.sub_layanan || '',
      deskripsi: payload.deskripsi,
      status: initialStatus,
      approval_level: approvalLevel,
      catatan: '',
      diupdate_oleh: '',
      id_alat: payload.id_alat || '',
      nama_alat: payload.nama_alat || '',
      jumlah_pinjam: payload.jumlah_pinjam || '',
      tgl_mulai_pinjam: payload.tgl_mulai_pinjam || '',
      tgl_selesai_pinjam: payload.tgl_selesai_pinjam || '',
      tgl_kembali_aktual: '',
      kondisi_kembali: '',
      created_at: now,
      sla_hari: slaHari,
      sla_deadline: slaDeadline,
      sla_status: slaStatus,
      solved_at: ''
    };

    // 1. Simpan ke Master Tickets
    appendDynamicRow('Master_Tickets', rowData);

    // 2. Simpan ke Sheet Kategori Spesifik
    const cats = getCategories();
    const cat = cats.find(function(c) { return c.nama === payload.kategori; });
    if(cat && cat.sheet_name) {
      appendDynamicRow(cat.sheet_name, rowData);
    }



    // 4. Update atau Simpan ke Requesters
    const sheetReq = ss.getSheetByName('Requesters');
    const reqData = sheetReq.getDataRange().getValues();
    const mapReq = getColumnMap(sheetReq);
    let found = false;

    // Deteksi apakah kontak adalah email atau nomor WA
    const kontakRaw = String(payload.kontak || '').trim();
    const isKontakEmail = kontakRaw.indexOf('@') !== -1;
    const waValue   = isKontakEmail ? '' : kontakRaw;
    const emailValue = isKontakEmail ? kontakRaw : (payload.email || '');

    const targetWaNorm = waValue ? normalizePhone(waValue) : '';
    const targetEmailNorm = emailValue.toLowerCase();
    
    for(let i=1; i<reqData.length; i++) {
      const existingWa = String(reqData[i][mapReq['whatsapp']] !== undefined ? reqData[i][mapReq['whatsapp']] : (reqData[i][mapReq['kontak']] || '')).trim();
      const existingEmail = String(mapReq['email'] !== undefined ? (reqData[i][mapReq['email']] || '') : '').trim();
      
      const matchWa = targetWaNorm && (normalizePhone(existingWa) === targetWaNorm);
      const matchEmail = targetEmailNorm && (existingEmail.toLowerCase() === targetEmailNorm);
      // Fallback: match by kontak column jika ada
      const existingKontak = String(mapReq['kontak'] !== undefined ? (reqData[i][mapReq['kontak']] || '') : '').trim();
      const matchKontak = kontakRaw && (existingKontak === kontakRaw);
      
      if (matchWa || matchEmail || matchKontak) {
        let currentTotal = Number(reqData[i][mapReq['total_request']]) || 0;
        sheetReq.getRange(i+1, mapReq['total_request']+1).setValue(currentTotal + 1);
        sheetReq.getRange(i+1, mapReq['last_request']+1).setValue(now);
        if (mapReq['nama'] !== undefined) sheetReq.getRange(i+1, mapReq['nama']+1).setValue(payload.nama);
        
        // Update field yang masih kosong
        if (mapReq['email'] !== undefined && !existingEmail && emailValue) {
          sheetReq.getRange(i+1, mapReq['email']+1).setValue(emailValue);
        }
        if (mapReq['whatsapp'] !== undefined && !existingWa && waValue) {
          sheetReq.getRange(i+1, mapReq['whatsapp']+1).setValue(waValue);
        }
        
        found = true;
        break;
      }
    }
    if(!found) {
      // Simpan ke kolom yang ada: whatsapp+email atau fallback ke kontak
      if (mapReq['whatsapp'] !== undefined) {
        sheetReq.appendRow([waValue, emailValue, payload.nama, 1, now]);
      } else {
        sheetReq.appendRow([kontakRaw, payload.nama, 1, now]);
      }
    }

    // 5. Save custom fields to Ticket_Details if present
    if (payload.custom_fields && typeof payload.custom_fields === 'object') {
      try {
        saveTicketDetails(ticketId, payload.custom_fields);
      } catch(cfErr) {
        Logger.log('Gagal simpan custom fields: ' + cfErr.toString());
      }
    }

    // 6. Save room booking if applicable
    if (payload.custom_fields && payload.custom_fields.id_ruangan && payload.custom_fields.tgl_pakai) {
      try {
        saveRoomBooking(ticketId, payload.nama, payload.custom_fields.id_ruangan, payload.custom_fields.tgl_pakai, payload.custom_fields.jam_mulai || '', payload.custom_fields.jam_selesai || '', payload.custom_fields.keperluan || payload.deskripsi);
      } catch(rbErr) {
        Logger.log('Gagal simpan room booking: ' + rbErr.toString());
      }
    }

    // 7. Save vehicle booking if applicable
    if (payload.custom_fields && payload.custom_fields.id_kendaraan && payload.custom_fields.tgl_berangkat) {
      try {
        saveVehicleBooking(ticketId, payload.nama, payload.custom_fields.id_kendaraan, payload.custom_fields.tgl_berangkat, payload.custom_fields.jam_berangkat || '', payload.custom_fields.jam_kembali || '', payload.custom_fields.tujuan || payload.deskripsi);
      } catch(vbErr) {
        Logger.log('Gagal simpan vehicle booking: ' + vbErr.toString());
      }
    }

    // Update jenis_pengajuan & id_template on Master_Tickets
    if (payload.jenis_pengajuan || payload.id_template) {
      try {
        var mtSheet = ss.getSheetByName('Master_Tickets');
        var mtData = mtSheet.getDataRange().getValues();
        var mtMap = getColumnMap(mtSheet);
        for (var mt = 1; mt < mtData.length; mt++) {
          if (String(mtData[mt][mtMap['ticket_id']]) === ticketId) {
            if (mtMap['jenis_pengajuan'] !== undefined) mtSheet.getRange(mt + 1, mtMap['jenis_pengajuan'] + 1).setValue(payload.jenis_pengajuan || payload.sub_layanan || '');
            if (mtMap['id_template'] !== undefined) mtSheet.getRange(mt + 1, mtMap['id_template'] + 1).setValue(payload.id_template || '');
            break;
          }
        }
      } catch(jpErr) {
        Logger.log('Gagal update jenis_pengajuan: ' + jpErr.toString());
      }
    }

    // --- NOTIFIKASI TIKET BARU ---
    try {
      const notifConf = getNotifConfig();
      // Prepare borrowInfo if borrowing fields exist
      let borrowInfo = null;
      if (payload.id_alat && payload.nama_alat && payload.jumlah_pinjam) {
        borrowInfo = {
          id_alat: payload.id_alat,
          nama_alat: payload.nama_alat,
          jumlah_pinjam: payload.jumlah_pinjam,
          tgl_mulai_pinjam: payload.tgl_mulai_pinjam || '',
          tgl_selesai_pinjam: payload.tgl_selesai_pinjam || ''
        };
      }

      // Paket identitas user untuk dikirim di notifikasi
      var userInfo = {
        whatsapp:          payload.whatsapp          || '',
        email:             payload.email             || '',
        divisi_pengaju:    payload.divisi_pengaju    || '',
        sub_divisi_pengaju: payload.sub_divisi_pengaju || '',
        jabatan_pengaju:   payload.jabatan_pengaju   || ''
      };
      
      // Build custom fields HTML and plain text
      var customFieldsHtml = '';
      var customFieldsText = '';
      if (payload.custom_fields && typeof payload.custom_fields === 'object') {
        try {
          customFieldsHtml = buildCustomFieldsHtml(payload.custom_fields);
          customFieldsText = buildCustomFieldsText(payload.custom_fields);
        } catch(cfErr) {
          Logger.log('Gagal menyusun detail kustom untuk notifikasi: ' + cfErr.toString());
        }
      }
      
      // Email ke Admin
      if (notifConf.enable_email === 'true') {
        var recipientEmail = notifConf.admin_email;
        if (recipientEmail) {
          kirimEmailAdminBaru(ticketId, payload.nama, payload.kategori, payload.sub_layanan || '', payload.deskripsi, borrowInfo, customFieldsHtml, recipientEmail, userInfo);
        }
        if (payload.sub_layanan === 'Void Bukti Setor' && notifConf.finance_admin_email) {
          kirimEmailAdminBaru(ticketId, payload.nama, payload.kategori, payload.sub_layanan || '', payload.deskripsi, borrowInfo, customFieldsHtml, notifConf.finance_admin_email, userInfo);
        }
      }
      // Notif ke User
      if (notifConf.enable_whatsapp === 'true' && notifConf.wa_gateway_url && notifConf.wa_api_key && payload.whatsapp) {
        kirimWhatsAppUserBaru(ticketId, payload.nama, payload.whatsapp, payload.kategori, payload.sub_layanan || '', payload.deskripsi, customFieldsText, userInfo);
      }
      if (notifConf.enable_email === 'true' && payload.email && isEmail(payload.email)) {
        kirimEmailUserBaru(ticketId, payload.nama, payload.email, payload.kategori, payload.sub_layanan || '', payload.deskripsi, borrowInfo, customFieldsHtml, userInfo);
      }
    } catch(notifErr) {
      Logger.log('Notifikasi gagal (tiket baru): ' + notifErr.toString());
    }

    return { success: true, ticket_id: ticketId };
  } catch(e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function updateTicketStatus(id, newStatus, catatan, updaterName, idDriver, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'update_ticket')) {
    return { success: false, message: 'Akses Ditolak: Anda tidak diizinkan mengubah status tiket' };
  }
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('Master_Tickets');
    const data = sheet.getDataRange().getValues();
    const map = getColumnMap(sheet);
    
    let ticketIdStr = '';
    let categoryStr = '';
    let oldStatus = '';

    for (let i = 1; i < data.length; i++) {
      if (String(data[i][map['id']]) === String(id)) {
        let targetRow = i + 1;
        oldStatus = String(data[i][map['status']] || '');
        sheet.getRange(targetRow, map['status'] + 1).setValue(newStatus);
        
        if (map['catatan'] !== undefined) {
          sheet.getRange(targetRow, map['catatan'] + 1).setValue(catatan || '');
        } else {
          let lastCol = sheet.getLastColumn();
          sheet.getRange(1, lastCol + 1).setValue('catatan');
          map['catatan'] = lastCol;
          sheet.getRange(targetRow, lastCol + 1).setValue(catatan || '');
        }

        if (map['diupdate_oleh'] !== undefined) {
          sheet.getRange(targetRow, map['diupdate_oleh'] + 1).setValue(updaterName || '');
        } else {
          let lastCol = sheet.getLastColumn();
          sheet.getRange(1, lastCol + 1).setValue('diupdate_oleh');
          map['diupdate_oleh'] = lastCol;
          sheet.getRange(targetRow, lastCol + 1).setValue(updaterName || '');
        }

        // Set approved_by and approved_at when moving from Open/Pending to On Proses/Solved
        if ((newStatus === 'On Proses' || newStatus === 'Solved') && (oldStatus === 'Open' || oldStatus === 'Pending' || !oldStatus)) {
          if (map['approved_by'] !== undefined) {
            sheet.getRange(targetRow, map['approved_by'] + 1).setValue(updaterName || '');
          }
          if (map['approved_at'] !== undefined) {
            sheet.getRange(targetRow, map['approved_at'] + 1).setValue(new Date());
          }
        }

        ticketIdStr = data[i][map['ticket_id']];
        categoryStr = data[i][map['kategori']];
        break;
      }
    }

    // Update di sheet spesifik kategori jika perlu konsistensi
    if(ticketIdStr && categoryStr) {
      const cats = getCategories();
      const cat = cats.find(function(c) { return c.nama === categoryStr; });
      if(cat && cat.sheet_name) {
        const sheetCat = ss.getSheetByName(cat.sheet_name);
        if(sheetCat) {
          const catData = sheetCat.getDataRange().getValues();
          const catMap = getColumnMap(sheetCat);
          for(let j=1; j<catData.length; j++) {
            if(String(catData[j][catMap['ticket_id']]) === String(ticketIdStr)) {
               let catTargetRow = j + 1;
               sheetCat.getRange(catTargetRow, catMap['status'] + 1).setValue(newStatus);
               
               if(catMap['catatan'] !== undefined) {
                 sheetCat.getRange(catTargetRow, catMap['catatan'] + 1).setValue(catatan || '');
               } else {
                 let lastColCat = sheetCat.getLastColumn();
                 sheetCat.getRange(1, lastColCat + 1).setValue('catatan');
                 catMap['catatan'] = lastColCat;
                 sheetCat.getRange(catTargetRow, lastColCat + 1).setValue(catatan || '');
               }

               if(catMap['diupdate_oleh'] !== undefined) {
                 sheetCat.getRange(catTargetRow, catMap['diupdate_oleh'] + 1).setValue(updaterName || '');
               } else {
                 let lastColCat = sheetCat.getLastColumn();
                 sheetCat.getRange(1, lastColCat + 1).setValue('diupdate_oleh');
                 sheetCat.getRange(catTargetRow, lastColCat + 1).setValue(updaterName || '');
               }
               break;
            }
          }
        }
      }
    }

    // Update Room_Bookings and Vehicle_Bookings status if applicable
    if (ticketIdStr) {
      try {
        var bookingStatus = 'Open';
        if (newStatus === 'On Proses') bookingStatus = 'Approved';
        else if (newStatus === 'Solved') bookingStatus = 'Solved';
        else if (newStatus === 'Reject' || newStatus === 'Batal') bookingStatus = 'Batal';
        else if (newStatus === 'Pending') bookingStatus = 'Pending';

        // 1. Room Bookings Sync
        var rbSheet = ss.getSheetByName('Room_Bookings');
        if (rbSheet && rbSheet.getLastRow() > 1) {
          var rbData = rbSheet.getDataRange().getValues();
          var rbMap = getColumnMap(rbSheet);
          for (var rbi = 1; rbi < rbData.length; rbi++) {
            if (String(rbData[rbi][rbMap['ticket_id']]) === String(ticketIdStr)) {
              var rbTargetRow = rbi + 1;
              rbSheet.getRange(rbTargetRow, rbMap['status'] + 1).setValue(bookingStatus);
              if (updaterName && rbMap['approved_by'] !== undefined) {
                rbSheet.getRange(rbTargetRow, rbMap['approved_by'] + 1).setValue(updaterName);
              }
              break;
            }
          }
        }

        // 2. Vehicle Bookings Sync
        var vbSheet = ss.getSheetByName('Vehicle_Bookings');
        if (vbSheet && vbSheet.getLastRow() > 1) {
          var vbData = vbSheet.getDataRange().getValues();
          var vbMap = getColumnMap(vbSheet);
          for (var vbi = 1; vbi < vbData.length; vbi++) {
            if (String(vbData[vbi][vbMap['ticket_id']]) === String(ticketIdStr)) {
              var vbTargetRow = vbi + 1;
              vbSheet.getRange(vbTargetRow, vbMap['status'] + 1).setValue(bookingStatus);
              if (idDriver && vbMap['id_driver'] !== undefined) {
                vbSheet.getRange(vbTargetRow, vbMap['id_driver'] + 1).setValue(idDriver);
              }
              if (updaterName && vbMap['approved_by'] !== undefined) {
                vbSheet.getRange(vbTargetRow, vbMap['approved_by'] + 1).setValue(updaterName);
              }
              break;
            }
          }
        }
      } catch(bookingSyncErr) {
        Logger.log('Gagal menyinkronkan status booking: ' + bookingSyncErr.toString());
      }
    }

    // Update return dates on Master_Tickets if status changed to completed
    if (isReturnedStatus(newStatus) && !isReturnedStatus(oldStatus)) {
      for (var ri = 1; ri < data.length; ri++) {
        if (String(data[ri][map['id']]) === String(id)) {
          // Update tgl_kembali_aktual on Master_Tickets
          if (map['tgl_kembali_aktual'] !== undefined) {
            sheet.getRange(ri + 1, map['tgl_kembali_aktual'] + 1).setValue(new Date());
          }
          // Update kondisi_kembali from catatan if provided
          if (map['kondisi_kembali'] !== undefined && catatan) {
            sheet.getRange(ri + 1, map['kondisi_kembali'] + 1).setValue(catatan);
          }
          break;
        }
      }
    }

    // Update solved_at if status becomes Solved
    if (newStatus === 'Solved' && oldStatus !== 'Solved') {
      for (var ri = 1; ri < data.length; ri++) {
        if (String(data[ri][map['id']]) === String(id)) {
          if (map['solved_at'] !== undefined) {
            sheet.getRange(ri + 1, map['solved_at'] + 1).setValue(new Date());
          }
          break;
        }
      }
    }

    // --- NOTIFIKASI PERUBAHAN STATUS ---
    try {
      const notifConf = getNotifConfig();
      let waUser = '';
      let emailUser = '';
      let namaUser = '';
      for (let i = 1; i < data.length; i++) {
        if (String(data[i][map['id']]) === String(id)) {
          waUser = String(data[i][map['whatsapp']] || '');
          emailUser = String(data[i][map['email']] || '');
          namaUser = String(data[i][map['nama']] || '');
          break;
        }
      }
      if (namaUser) {
        if (notifConf.enable_whatsapp === 'true' && notifConf.wa_gateway_url && notifConf.wa_api_key && waUser) {
          kirimWhatsAppBalasanUser(ticketIdStr, namaUser, waUser, catatan || '', newStatus);
        }
        if (notifConf.enable_email === 'true' && emailUser && isEmail(emailUser)) {
          kirimEmailBalasanUser(ticketIdStr, namaUser, emailUser, catatan || '', newStatus);
        }
      }
    } catch(notifErr) {
      Logger.log('Notifikasi gagal (update status): ' + notifErr.toString());
    }

    return { success: true };
  } catch (e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function normalizeTicketId(input) {
  if (!input) return '';
  // Bersihkan input: hapus spasi dan ubah ke uppercase
  var cleaned = String(input).trim().toUpperCase().replace(/\s+/g, '');
  // Jika input sudah format lengkap TKT-XXXX-XXXX, kembalikan apa adanya
  if (/^TKT-\d{4}-\d{4,}$/.test(cleaned)) return cleaned;
  // Jika input format parsial TKT-XXXX (tanpa segment terakhir)
  if (/^TKT-\d+/.test(cleaned)) return cleaned;
  // Jika input hanya angka, kembalikan untuk pencarian substring
  if (/^\d+$/.test(cleaned)) return cleaned;
  // Tambahkan prefix TKT- jika belum ada
  if (!cleaned.startsWith('TKT')) cleaned = 'TKT-' + cleaned;
  return cleaned;
}

function trackTicket(ticketId) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Master_Tickets');
  if(!sheet) return { success: false, message: 'Sistem error' };
  
  const data = sheet.getDataRange().getValues();
  const map = getColumnMap(sheet);
  const normalized = normalizeTicketId(ticketId);
  
  if (!normalized) return { success: false, message: 'ID Tiket tidak valid' };
  
  // 1. Coba exact match dulu
  for(let i=1; i<data.length; i++) {
    if(String(data[i][map['ticket_id']]).toUpperCase() === normalized) {
      return buildTrackResult(data[i], map, data[i][map['ticket_id']]);
    }
  }
  
  // 2. Jika tidak ditemukan, coba partial/substring match
  var matches = [];
  for(let i=1; i<data.length; i++) {
    var storedId = String(data[i][map['ticket_id']]).toUpperCase();
    if(storedId.includes(normalized)) {
      matches.push({ row: data[i], ticketId: data[i][map['ticket_id']] });
    }
  }
  
  if (matches.length === 1) {
    return buildTrackResult(matches[0].row, map, matches[0].ticketId);
  } else if (matches.length > 1) {
    // Kembalikan daftar tiket yang cocok agar user bisa memilih
    var matchIds = matches.map(m => m.ticketId).join(', ');
    return { success: false, message: 'Ditemukan ' + matches.length + ' tiket yang cocok: ' + matchIds + '. Silakan masukkan ID lengkap.' };
  }
  
  return { success: false, message: 'Tiket tidak ditemukan' };
}

function buildTrackResult(row, map, ticketId) {
  return {
    success: true,
    data: {
      ticket_id: row[map['ticket_id']],
      nama: row[map['nama']],
      kategori: row[map['kategori']],
      sub_layanan: (map['sub_layanan'] !== undefined) ? row[map['sub_layanan']] : '',
      divisi_pengaju: (map['divisi_pengaju'] !== undefined) ? row[map['divisi_pengaju']] : '',
      sub_divisi_pengaju: (map['sub_divisi_pengaju'] !== undefined) ? row[map['sub_divisi_pengaju']] : '',
      jabatan_pengaju: (map['jabatan_pengaju'] !== undefined) ? row[map['jabatan_pengaju']] : '',
      status: row[map['status']],
      approval_level: (map['approval_level'] !== undefined) ? row[map['approval_level']] : '',
      catatan: (map['catatan'] !== undefined) ? row[map['catatan']] : '',
      diupdate_oleh: (map['diupdate_oleh'] !== undefined) ? row[map['diupdate_oleh']] : '',
      created_at: safeDateFormat(row[map['created_at']]),
      attachments: getTicketAttachments(String(ticketId))
    }
  };
}


// --- CRUD MASTER LAYANAN (CATEGORIES) ---
function saveCategory(payload, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat mengelola unit.' };
  }
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const catSheet = ss.getSheetByName('Categories');
    const data = catSheet.getDataRange().getValues();
    const map = getColumnMap(catSheet);

    if (!payload.nama) return { success: false, message: 'Nama layanan wajib diisi' };

    if (payload.isEdit) {
      let oldNama = '';
      for (let i = 1; i < data.length; i++) {
        if (String(data[i][map['id']]) === String(payload.id)) {
          oldNama = data[i][map['nama']];
          catSheet.getRange(i + 1, map['nama'] + 1).setValue(payload.nama);
          if (map['deskripsi'] !== undefined) {
            catSheet.getRange(i + 1, map['deskripsi'] + 1).setValue(payload.deskripsi || '');
          }
          break;
        }
      }

      // Update cascading names
      if (oldNama && oldNama !== payload.nama) {
        const masterSheet = ss.getSheetByName('Master_Tickets');
        if(masterSheet) {
          const masterData = masterSheet.getDataRange().getValues();
          const masterMap = getColumnMap(masterSheet);
          for (let j = 1; j < masterData.length; j++) {
            if (masterData[j][masterMap['kategori']] === oldNama) {
              masterSheet.getRange(j + 1, masterMap['kategori'] + 1).setValue(payload.nama);
            }
          }
        }
        
        // Update di Sheet Sub Categories juga
        const subCatSheet = ss.getSheetByName('Sub_Categories');
        if (subCatSheet) {
          const subData = subCatSheet.getDataRange().getValues();
          const subMap = getColumnMap(subCatSheet);
          for (let k = 1; k < subData.length; k++) {
            if (subData[k][subMap['kategori']] === oldNama) {
              subCatSheet.getRange(k + 1, subMap['kategori'] + 1).setValue(payload.nama);
            }
          }
        }
      }
      return { success: true };
      
    } else {
      const newSheetName = 'Cat_' + payload.nama.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 20);
      if (ss.getSheetByName(newSheetName)) return { success: false, message: 'Sheet untuk layanan ini sudah ada.' };
      
      const newSheet = ss.insertSheet(newSheetName);
      newSheet.appendRow(['ticket_id', 'nama', 'whatsapp', 'email', 'divisi_pengaju', 'sub_divisi_pengaju', 'jabatan_pengaju', 'deskripsi', 'sub_layanan', 'status', 'catatan', 'diupdate_oleh', 'created_at']);
      newSheet.getRange('A1:L1').setFontWeight('bold').setBackground('#f3f4f6');
      newSheet.setFrozenRows(1);
      newSheet.setColumnWidth(1, 120);
      newSheet.setColumnWidth(2, 200);
      newSheet.setColumnWidth(4, 300);

      let rowToInsert = [];
      const headers = data[0];
      headers.forEach(h => {
        let key = String(h).toLowerCase().trim();
        if(key === 'id') rowToInsert.push(Date.now());
        else if(key === 'nama') rowToInsert.push(payload.nama);
        else if(key === 'deskripsi') rowToInsert.push(payload.deskripsi || '');
        else if(key === 'sheet_name') rowToInsert.push(newSheetName);
        else if(key === 'status') rowToInsert.push('Active');
        else if(key === 'created_at') rowToInsert.push(new Date());
        else rowToInsert.push('');
      });
      catSheet.appendRow(rowToInsert);

      return { success: true };
    }
  } catch(e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

// --- CRUD KATEGORI LAYANAN (SUB CATEGORIES) ---
function saveSubCategory(payload, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat mengelola kategori.' };
  }
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('Sub_Categories');
    const data = sheet.getDataRange().getValues();
    const map = getColumnMap(sheet);
    
    if (!payload.nama || !payload.parent_nama) return { success: false, message: 'Data tidak lengkap' };
    
    if (payload.isEdit) {
      let oldNama = '';
      for (let i = 1; i < data.length; i++) {
        if (String(data[i][map['id_sub'] || map['id']]) === String(payload.id)) {
          oldNama = data[i][map['nama_sub'] || map['nama']];
          if(map['kategori'] !== undefined) sheet.getRange(i + 1, map['kategori'] + 1).setValue(payload.parent_nama);
          else if(map['parent_nama'] !== undefined) sheet.getRange(i + 1, map['parent_nama'] + 1).setValue(payload.parent_nama);
          
          if(map['nama_sub'] !== undefined) sheet.getRange(i + 1, map['nama_sub'] + 1).setValue(payload.nama);
          else if(map['nama'] !== undefined) sheet.getRange(i + 1, map['nama'] + 1).setValue(payload.nama);
          
          if(map['sla_hari'] !== undefined) sheet.getRange(i + 1, map['sla_hari'] + 1).setValue(payload.sla_hari || 3);
          
          break;
        }
      }
      
      // Update existing tickets with new sub_layanan name
      if (oldNama && oldNama !== payload.nama) {
        const masterSheet = ss.getSheetByName('Master_Tickets');
        if(masterSheet) {
          const masterData = masterSheet.getDataRange().getValues();
          const masterMap = getColumnMap(masterSheet);
          if (masterMap['sub_layanan'] !== undefined) {
             for (let j = 1; j < masterData.length; j++) {
                if (masterData[j][masterMap['sub_layanan']] === oldNama) {
                  masterSheet.getRange(j + 1, masterMap['sub_layanan'] + 1).setValue(payload.nama);
                }
             }
          }
        }

        // Sync nama_pengajuan di Ticket_Fields
        const tfSheet = ss.getSheetByName('Ticket_Fields');
        if (tfSheet && tfSheet.getLastRow() > 1) {
          const tfData = tfSheet.getDataRange().getValues();
          const tfMap  = getColumnMap(tfSheet);
          if (tfMap['nama_pengajuan'] !== undefined) {
            for (let k = 1; k < tfData.length; k++) {
              if (String(tfData[k][tfMap['nama_pengajuan']]) === oldNama) {
                tfSheet.getRange(k + 1, tfMap['nama_pengajuan'] + 1).setValue(payload.nama);
              }
            }
          }
        }

        // Sync nama_pengajuan di Form_Settings
        const fsSheet = ss.getSheetByName('Form_Settings');
        if (fsSheet && fsSheet.getLastRow() > 1) {
          const fsData = fsSheet.getDataRange().getValues();
          const fsMap  = getColumnMap(fsSheet);
          if (fsMap['nama_pengajuan'] !== undefined) {
            for (let m = 1; m < fsData.length; m++) {
              if (String(fsData[m][fsMap['nama_pengajuan']]) === oldNama) {
                fsSheet.getRange(m + 1, fsMap['nama_pengajuan'] + 1).setValue(payload.nama);
              }
            }
          }
        }
      }
    } else {
      let rowToInsert = [];
      const headers = data[0];
      headers.forEach(h => {
        let key = String(h).toLowerCase().trim();
        if(key === 'id' || key === 'id_sub') rowToInsert.push(Date.now());
        else if(key === 'parent_nama' || key === 'kategori') rowToInsert.push(payload.parent_nama);
        else if(key === 'nama' || key === 'nama_sub') rowToInsert.push(payload.nama);
        else if(key === 'sla_hari') rowToInsert.push(payload.sla_hari || 3);
        else if(key === 'status') rowToInsert.push('Active');
        else if(key === 'created_at') rowToInsert.push(new Date());
        else rowToInsert.push('');
      });
      sheet.appendRow(rowToInsert);
    }
    
    return { success: true };
  } catch(e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

function deleteSubCategory(id, currentUserRole) {
  if (!currentUserRole || !checkPermission(currentUserRole, 'manage_config')) {
    return { success: false, message: 'Akses Ditolak: Hanya Admin yang dapat menghapus kategori.' };
  }
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Sub_Categories');
    if (!sheet) return { success: false, message: 'Sheet tidak ditemukan' };
    
    const data = sheet.getDataRange().getValues();
    const map = getColumnMap(sheet);
    
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][map['id']]) === String(id)) {
        sheet.deleteRow(i + 1);
        return { success: true };
      }
    }
    return { success: false, message: 'Kategori tidak ditemukan' };
  } catch(e) {
    return { success: false, message: e.toString() };
  } finally {
    lock.releaseLock();
  }
}

